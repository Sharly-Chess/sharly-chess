# Example .env file for macOS signing and notarization
# Copy this file to .env and fill in your actual values
# DO NOT commit the actual .env file to version control!

# Apple Developer Account Credentials for Notarization
# Your Apple ID email address
APPLE_ID=your_apple_id@example.com

# App-specific password generated in your Apple ID account
# Create one at: https://appleid.apple.com/account/manage -> Sign-In and Security -> App-Specific Passwords
APPLE_APP_SPECIFIC_PASSWORD=abcd-efgh-ijkl-mnop

# Your Apple Developer Team ID (10-character string)
# Find it at: https://developer.apple.com/account -> Membership Details
APPLE_TEAM_ID=ABCDEFGHIJ

# macOS Code Signing Certificate
# Base64-encoded .p12 certificate file containing your "Developer ID Application" certificate
# To generate: Export certificate from Keychain Access as .p12, then run:
# base64 -i /path/to/your/certificate.p12 -o -
MACOS_SIGNING_CERT_BASE64=MIIKoQIBAzCCCl0GCSqGSIb3DQEHAaCCCk4EggpKMIIKRjCCBQIGCSqGSIb3DQEHAaCCBPMEggTvMIIE6zCCBOcGCyqGSIb3DQEMCgECoIIE7jCCBOowHAYKKoZIhvcNAQwBAzAOBAhQdR7vdVJL0wICB9AEggTIxample...

# Password for the .p12 certificate file
MACOS_SIGNING_CERT_PASSWORD=your_certificate_password_here
