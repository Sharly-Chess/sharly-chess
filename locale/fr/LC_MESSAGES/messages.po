msgstr "Cet écran est public (visible des utilisateur·ices)."

#: src/web/templates/common/macros.j2
msgid "This screen family is public (visible by the users)."
msgstr "Cette famille d'écrans est publique (visible des utilisateur·ices)."

#: src/web/templates/common/macros.j2
