#: src/web/templates/admin/tournaments/tournament_modal.html
#, python-format
msgid "Deletion of tournament [%(tournament_uniq_id)s]"
msgstr "Suppression du tournoi [%(tournament_uniq_id)s]"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Warning: the deletion of a tournament is permanent!"
msgstr "Attention : la suppression d'un tournoi est définitive !"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The following screens will also be deleted:"
msgstr "Les écrans suivants vont également être supprimés :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The following screen families will also be deleted:"
msgstr "Les familles d'écrans suivantes vont également être supprimées :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Enter the tournament ID to confirm its deletion:"
msgstr "Entrez l'identifiant du tournoi pour confirmer sa suppression :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Enter here the tournament ID"
msgstr "Entrez ici l'identifiant du tournoi"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The Papi-web tournament are deleted but the Papi file is still available on the filesystem."
msgstr "Le tournoi Papi-web ets supprimé mais le fichier Papi est conservé sur la système de fichiers."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "E.g.: main"
msgstr "Exemple : principal"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The Unique ID, used to reference the tournament."
msgstr "L'identifiant unique, utilisé pour référencer le tournoi."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "E.g.: Main tournament"
msgstr "Exemple : Tournoi principal"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The name of the tournament, used for display."
msgstr "Le nom du tournoi, utilisé pour l'affichage."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Directory of the Papi file:"
msgstr "Répertoire du fichier Papi :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "E.g.: c:\\chess\\tournaments\\papi"
msgstr "E.g.: c:\\echecs\\tournois\\papi"

#: src/web/templates/admin/tournaments/tournament_modal.html
#, python-format
msgid "The directory of the Papi file, by default %(dir)s."
msgstr "Le répertoire du fichier Papi, par défaut %(dir)s."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Name of the Papi file (with no extension):"
msgstr "Nom du fichier Papi (sans l'extension) :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The name of the Papi file, without the .papi extension (by default the FFE qualification number of the tournament, then The Unique ID of the tournament)."
msgstr "Le nom du fichier papi, sans l'extension Papi (par défaut le numéro d'homologation FFE, puis l'identifiant de l'évènement)."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Connections (FFE and ChessEvent)"
msgstr "Connexions (FFE et ChessEvent)"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "FFE qualification number (optional):"
msgstr "Numéro d'homologation FFE (facultatif) :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The qualification number given by the French Federation is an integer, it is used to connect to the FFE website."
msgstr "Le numéro d'homologation donné par la Fédération Française est un entier, il est utilisé pour la connexion au site web de la FFE."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "FFE password:"
msgstr "Mot de passe FFE :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The password is made of 10 uppercase letters, it is used to connect to the FFE website."
msgstr "La mot de passe est composé de 10 caractères majuscules, il est utilisé pour la connexion au site web de la FFE."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The ID used to connect to the ChessEvent platform (by default the ChessEvent ID defined for the Papi-web event of the tournament)."
msgstr "L'identifiant utilisé pour se connecter sur la plateforme ChessEvent (par défaut l'identifiant ChessEvent défini pour l'évènement Papi-web du tournoi)."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The password used to connect to the ChessEvent platform (by default the password defined for the Papi-web event of the tournament)."
msgstr "Le mot de passe utilisé pour se connecter sur la plateforme ChessEvent (par défaut le mot de passe ChessEvent défini pour l'évènement Papi-web du tournoi)."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The ID of the event on the ChessEvent platform (default the ChessEvent event ID defined for the Papi-web event of the tournament)."
msgstr "L'identifiant l'évènement sur la plateforme ChessEvent (par défaut l'identifiant de l'évènement ChessEvent défini pour l'évènement Papi-web du tournoi)."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "ChessEvent tournament:"
msgstr "Nom du tournoi ChessEvent :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "E.g.: Tournoi A"
msgstr "Exemple : Tournoi A"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The name of the tournament on the ChessEvent platform."
msgstr "Le nom du tournoi sur la plateforme ChessEvent."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Time control"
msgstr "Cadence"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Initial time (optional):"
msgstr "Temps initial (facultatif) :"

#: src/web/templates/admin/tournaments/tournament_modal.html
#, python-format
msgid "E.g.: %(seconds)d (%(minutes)d minutes)"
msgstr "Exemple : %(seconds)d (%(minutes)d minutes)"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The initial time in seconds (may be empty if an increment is set)."
msgstr "Le temps initial en secondes (peut être nul en cas d'incrément)."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Increment (optional):"
msgstr "Incrément (facultatif) :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The number of seconds added to the players' clock at each move."
msgstr "Le nombre de secondes ajoutés à la pendules des joueur·euses à chaque coup."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Penalty (handicap):"
msgstr "Pénalité (handicap) :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The time subtracted from the highest ranked player, in seconds (this time is multiplied by the number of difference steps between the two players)."
msgstr "Le temps retranché au·à la joueur·euse le·la mieux classé·e, en secondes (ce temps est multiplié par le nombre de tranches de différence entre les deux joueur·euses)."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Elo step (handicap):"
msgstr "Tranche Elo (handicap) :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "E.g.: 50 (Elo)"
msgstr "Exemple : 50 (Elo)"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The number of points difference between the ranking of the players used to calculate the number of penalties applied to the highest ranked player."
msgstr "Le nombre de points de différence entre le classement des joueur·euses utilisé pour calculer le nombre de pénalités appliqué au·à la joueur·euse le·la mieux classé·e."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "Minimal time (handicap):"
msgstr "Temps minimal (handicap) :"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "The minimum time, whatever the ranking difference between the two players."
msgstr "La temps minimal, quelle que soit la différence de classement entre les deux joueur·euses."

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "E.g.: c:\\chess\\tournaments\\main\\rules.pdf"
msgstr "Exemple : c:\\echecs\\tournois\\principal\\reglement.pdf"

#: src/web/templates/admin/tournaments/tournament_modal.html
msgid "A URL, or the path to the rules file on the server, in PDF format (optional, by default the rules files of the event)."
msgstr "Une URL, ou l'emplacement du règlement sur le serveur, au format PDF (facultatif, par défaut l'emplacement du règlement de l'évènement)."

#: src/web/templates/admin/tournaments/tournament_modal.html
#, python-format
msgid "The maximum number of illegal moves that can be recorded per round for a player (from 0 to 3, by default %(default)d)."
msgstr "Le nombre maximum de coups illégaux que l'on peut enregistrer par ronde pour un·e joueur·euse (de 0 à 3, par défaut %(default)d)."

