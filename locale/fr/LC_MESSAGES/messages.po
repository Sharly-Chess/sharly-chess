msgstr "Les adresses mél."

#, python-format
msgid "The maximum age of the results, in minutes (by default %(minutes)d minutes)."
msgstr "L'âge maximal des résultats affichés sur l'écran, en minutes (par défaut %(minutes)d minutes)."

#, python-format
msgid "The maximum number of byes a player can pretend to (if not set, defaults to %(default)d)."
msgstr "Le nombre maximum de byes auquel un·e joueur·euse peut prétendre (si non défini, %(default)d par défaut)."

#, python-format
msgid "The maximum number of illegal moves that can be recorded per round for a player (from 0 to 3, by default %(default)d)."
msgstr "Le nombre maximum de coups illégaux que l'on peut enregistrer par ronde pour un·e joueur·euse (de 0 à 3, par défaut %(default)d)."

#, python-format
