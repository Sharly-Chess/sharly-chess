msgid_plural "The {count} least and the {count} most significant values are removed."
msgstr[0] "La valeur la moins élevée et la valeur la plus élevée sont retirées."
msgstr[1] "Les {count} valeurs les moins élevées et les {count} valeurs les plus élevées sont retirées."

msgid "The least significant value is removed."
msgid_plural "The {count} least significant values are removed."
msgstr[0] "La valeur la moins élevée est retirée."
msgstr[1] "Les {count} valeurs les moins élevées sont retirées."

msgid "The limit can only be adjusted by {count} half-points."
msgstr "La limite ne peut être ajustée que de {count} demi-points."

msgid "The lowest rating that a player should have for their expected score to be greater than or equal to their score."
msgstr "Le classement le plus bas qu'un·e joueur·euse doit avoir pour que son score attendu soit supérieur ou égal à son score réel."

msgid "The main category is open to all the players."
msgstr "La catégorie générale est ouverte à tou·tes les joueur·euses."

#, python-format
