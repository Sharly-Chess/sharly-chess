#, ai_translation
msgid "ChessEvent connection:"
msgstr "Conexión ChessEvent:"

#: src/web/templates/admin_tournament_modal.html:230
#, ai_translation
msgid "The ChessEvent connection allows the retrieval of registrations from the ChessEvent platform."
msgstr "La conexión ChessEvent permite la recuperación de registros desde la plataforma ChessEvent."

#: src/web/templates/admin_tournament_modal.html:241
#, ai_translation
msgid "Name of the ChessEvent tournament:"
msgstr "Nombre del torneo ChessEvent:"

#: src/web/templates/admin_tournament_modal.html:250
#, ai_translation
msgid "The name of the tournament on the ChessEvent platform."
msgstr "El nombre del torneo en la plataforma ChessEvent."

#: src/web/templates/admin_tournament_modal.html:265
#, ai_translation
msgid "Time control"
msgstr "Control del tiempo"

#: src/web/templates/admin_tournament_modal.html:276
#, ai_translation, python-format
msgid "E.g.: %(seconds)d (%(minutes)d minutes)"
msgstr "Por ejemplo: %(seconds)d (%(minutes)d minutos)"

#: src/web/templates/admin_tournament_modal.html:279
#, ai_translation
msgid "The initial time in seconds (may be nul if an increment is set)."
msgstr "El tiempo inicial en segundos (puede ser nulo si se establece un incremento)."

#: src/web/templates/admin_tournament_modal.html:290
#, ai_translation
msgid "Increment (optional):"
msgstr "Incremento (opcional):"

#: src/web/templates/admin_tournament_modal.html:299
#, ai_translation
msgid "The number of seconds added to the players' clock at each move."
msgstr "El número de segundos añadidos al reloj de los jugadores en cada movimiento."

#: src/web/templates/admin_tournament_modal.html:310
#, ai_translation
msgid "Penalty (handicap):"
msgstr "Pena (hadicap):"

#: src/web/templates/admin_tournament_modal.html:319
#, ai_translation
msgid "The time subtracted from the highest ranked player, in seconds (this time is multiplied by the number of difference steps between the two players)."
msgstr "El tiempo restado del jugador más alto, en segundos (esta vez se multiplica por el número de pasos de diferencia entre los dos jugadores)."

#: src/web/templates/admin_tournament_modal.html:330
#, ai_translation
msgid "Elo step (handicap):"
msgstr "Paso de Elo (handicap):"

#: src/web/templates/admin_tournament_modal.html:336
#, ai_translation
msgid "E.g.: 50 (Elo)"
msgstr "Por ejemplo: 50 (Elo)"

#: src/web/templates/admin_tournament_modal.html:339
#, ai_translation
msgid "The number of points difference between the ranking of the players used to calculate the number of penalties applied to the highest ranked player."
msgstr "El número de puntos de diferencia entre el ranking de los jugadores utilizados para calcular el número de penalidades aplicadas al jugador más clasificado."

#: src/web/templates/admin_tournament_modal.html:350
#, ai_translation
msgid "Minimal time (handicap):"
msgstr "Tiempo mínimo (handicap):"

#: src/web/templates/admin_tournament_modal.html:359
#, ai_translation
msgid "The minimum time, whatever the ranking difference between the two players."
msgstr "El tiempo mínimo, cualquiera que sea la diferencia de clasificación entre los dos jugadores."

#: src/web/templates/admin_tournament_modal.html:381
#, ai_translation
msgid "E.g.: c:\\chess\\tournaments\\main\\rules.pdf"
msgstr "Por ejemplo: c:\\chess\\tournaments\\main\\rules.pdf"

#: src/web/templates/admin_tournament_modal.html:384
#, ai_translation
msgid "A URL, or the path to the rules file on the server, in PDF format (optional, by default the rules files of the event)."
msgstr "Una URL, o la ruta al archivo de reglas en el servidor, en formato PDF (opcional, por defecto los archivos de reglas del evento)."

#: src/web/templates/admin_tournament_modal.html:406
#, ai_translation, python-format
msgid "The maximum number of illegal moves that can be recorded per round for a player (from 0 to 3, by default %(default)d)."
msgstr "El número máximo de movimientos ilegales que se pueden registrar por ronda para un jugador (de 0 a 3, por defecto %(default)d)."

