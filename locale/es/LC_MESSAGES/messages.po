msgstr "Contraseña FFE:"

#: src/web/templates/admin_tournament_modal.html:195
#, ai_translation
msgid "The password is made of 10 uppercase letters, it is used to connect to the FFE website."
msgstr "La contraseña está hecha de 10 letras mayúsculas, se utiliza para conectarse al sitio web de la FFE."

