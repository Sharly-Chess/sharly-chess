{
  "app-id": "com.sharlychess.SharlyChess",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.gnome.Sdk.Locale"
  ],
  "command": "sharly-chess-launcher",
  "separate-locales": false,
  "finish-args": [
    "--socket=wayland",
    "--socket=x11",
    "--socket=pulseaudio",
    "--share=network",
    "--filesystem=home:rw",
    "--device=dri",
    "--env=PYTHONUNBUFFERED=1",
    "--env=PYTHONPATH=/app/lib/python3.12/site-packages"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/lib/*.la",
    "/lib/*.a",
    "/share/pkgconfig",
    "/share/aclocal",
    "/man",
    "/share/man",
    "/share/doc",
    "/share/gtk-doc",
    "*.pyc",
    "__pycache__"
  ],
  "build-options": {
    "cflags": "-O2 -g",
    "cxxflags": "-O2 -g",
    "env": {
      "LDFLAGS": "-L/app/lib",
      "CFLAGS": "-I/app/include"
    }
  },
  "modules": [
    {
      "name": "libffi",
      "config-opts": [
        "--disable-static",
        "--disable-docs"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/libffi/libffi/releases/download/v3.4.6/libffi-3.4.6.tar.gz",
          "sha256": "b0dea9df23c863a7a50e825440f3ebffabd65df1497108e5d437747843895a4e"
        }
      ]
    },
    {
      "name": "openssl",
      "buildsystem": "simple",
      "build-commands": [
        "LDFLAGS=-L/app/lib ./config shared --prefix=/app --openssldir=/app/etc/ssl",
        "make",
        "make install_sw",
        "rm -f /app/lib/libssl.a /app/lib/libcrypto.a"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://www.openssl.org/source/openssl-3.0.13.tar.gz",
          "sha256": "88525753f79d3bec27d2fa7c66aa0b92b3aa9498dafd93d7cfa4b3780cdae313"
        }
      ]
    },
    {
      "name": "python-dependencies",
      "buildsystem": "simple",
      "build-options": {
        "build-args": [
          "--share=network"
        ]
      },
      "build-commands": [
        "pip3 install --prefix=/app --ignore-installed -r requirements-flatpak.txt 2>&1 | tee pip-install.log",
        "mkdir -p /app/share/sharly-chess",
        "echo 'Pip dependencies installed successfully' > /app/share/sharly-chess/pip-install.log",
        "cp /app/share/sharly-chess/pip-install.log /app/lib/pip-install.log || true"
      ],
      "sources": [
        {
          "type": "file",
          "path": "../../requirements-flatpak.txt"
        }
      ]
    },
    {
      "name": "sharly-chess",
      "buildsystem": "simple",
      "build-options": {
        "build-args": [
          "--share=network"
        ]
      },
      "build-commands": [
        "mkdir -p /app/share/sharly-chess",
        "pip3 install --prefix=/app --no-deps . 2>&1 | tee /tmp/app-install.log",
        "cp -r src/* /app/lib/python3.12/site-packages/",
        "cp -r locale /app/lib/python3.12/",
        "cp pyproject.toml /app/lib/python3.12/",
        "PYTHONPATH=/app/lib/python3.12/site-packages python3 -c \"import os; os.environ.pop('FLATPAK_ID', None); import sys; sys.path.append('src'); from common.i18n.babel_updaters import BabelUpdater; from common.i18n.domains import Domain; from common.i18n import locales, DEFAULT_LOCALE; BabelUpdater(Domain.get_domains(), locales, DEFAULT_LOCALE).create_absent_mo_files()\"",
        "cp -r examples /app/lib/python3.12/",
        "install -Dm755 flatpak/scripts/launcher.py /app/bin/sharly-chess-launcher",
        "chmod +x /app/bin/sharly-chess-launcher",
        "install -Dm644 flatpak/configuration/com.sharlychess.SharlyChess.desktop /app/share/applications/com.sharlychess.SharlyChess.desktop",
        "install -Dm644 flatpak/configuration/com.sharlychess.SharlyChess.appdata.xml /app/share/appdata/com.sharlychess.SharlyChess.appdata.xml",
        "PYTHONPATH=/app/lib/python3.12/site-packages python3 - <<'PY'\nfrom pathlib import Path\nfrom PIL import Image\n\nsrc = Path('src/web/static/images/sharly-chess.png')\nsizes = (256, 128)\nout_root = Path('/app/share/icons/hicolor')\nimg = Image.open(src)\nfor size in sizes:\n    out_dir = out_root / f\"{size}x{size}\" / 'apps'\n    out_dir.mkdir(parents=True, exist_ok=True)\n    resized = img.resize((size, size), Image.LANCZOS)\n    resized.save(out_dir / 'com.sharlychess.SharlyChess.png')\nPY",
        "install -Dm644 LICENSE.md /app/share/licenses/com.sharlychess.SharlyChess/LICENSE.md",
        "PYTHONPATH=/app/lib/python3.12/site-packages /app/bin/pip-licenses --with-system --with-authors --with-urls --with-description --format=markdown --output-file=/app/share/licenses/com.sharlychess.SharlyChess/THIRD_PARTY_LICENSES.md",
        "PYTHONPATH=/app/lib/python3.12/site-packages python3 flatpak/scripts/generate_notice.py /app/share/licenses/com.sharlychess.SharlyChess/NOTICE.txt",
        "PYTHONPATH=/app/lib/python3.12/site-packages python3 scripts/ffe/generate_ffe_sql_server_credentials.py --host=$FFE_HOST --user=$FFE_USER --password=$FFE_PASSWORD --database=$FFE_DATABASE --github",
        "PYTHONPATH=/app/lib/python3.12/site-packages python3 scripts/chess_results/generate_chess_results_credentials.py --key=$CHESS_RESULTS_KEY --iv=$CHESS_RESULTS_IV",
        "echo 'Build completed successfully' > /app/share/sharly-chess/build-info.txt"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "../.."
        }
      ]
    }
  ]
}
