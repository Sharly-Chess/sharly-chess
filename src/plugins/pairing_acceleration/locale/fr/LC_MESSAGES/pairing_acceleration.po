#, python-format
msgid "%(string)s:"
msgstr "%(string)s :"

msgid "Accelerated pairings"
msgstr "Appariements accélérés"

msgid "Accelerated variations of the swiss pairing system."
msgstr "Variantes accélérées du système d'appariements suisse."

msgid "Acceleration groups"
msgstr "Groupes d'accélération"

msgid "Baku acceleration system"
msgstr "Système d'accélération de Bakou"

msgid "Group {group_id}"
msgstr "Groupe {group_id}"

msgid "Groups can't be edited for this pairing system."
msgstr "Les groupes ne peuvent être mis à jour pour ce système d'appariement."

#, python-format
msgid "Groups must be composed of at least 25%% and at most 50%% of players."
msgstr "Les groupes doivent être composés d'au moins 25%% et d'au plus 50%% des joueur·euses."

#, python-format
msgid "Groups must be composed of at least 25%% of players."
msgstr "Les groupes doivent être composés d'au moins 25%% des joueur·euses."

msgid "Haley system"
msgstr "Système de Haley"

msgid "Maximum value must be greater than the minimum value."
msgstr "La valeur maximale doit être supérieure à la valeur minimale."

msgid "No acceleration."
msgstr "Pas d'accélération."

msgid "Pairing number range of players the group."
msgstr "Plage de numéros d'appariement des joueur·euses du groupe."

#, python-format
msgid "Pairing number range of the group (recommended: %(min)d-%(max)d)."
msgstr "Plage de numéros d'appariement du groupe (recommandé : %(min)d-%(max)d)."

msgid "Positive values are expected."
msgstr "Des valeurs positives sont attendues."

msgid "Progressive accelerated system"
msgstr "Système accéléré dégressif (SAD)"

msgid "Round {round}"
msgstr "Ronde {round}"

msgid "Rounds {min_round}-{max_round}"
msgstr "Rondes {min_round}-{max_round}"

msgid "Soft Haley system"
msgstr "Système de Haley dégressif"

msgid "Virtual points"
msgstr "Points virtuels"

msgid "Virtual points are granted to players according to their group. Those points only are used for pairing, not for ranking."
msgstr "Des points virtuels sont accordés aux joueur·euses selon leur groupe. Ces points ne sont utilisés que pour l'appariement, pas pour le classement."

msgid "points"
msgstr "points"

