{% macro visibility_icon(object_type, public, tooltip_public_text, tooltip_private_text, class='') %}
    <!-- visibility_icon() -->
    {% if public %}
        {% if object_type == 'event' %}
            {% set _tooltip_text=tooltip_public_text or _('This event is public (by default, screens are visible by the spectators).') %}
        {% elif object_type == 'screen' %}
            {% set _tooltip_text=tooltip_public_text or _('This screen is public (visible by the spectators).') %}
        {% elif object_type == 'family' %}
            {% set _tooltip_text=tooltip_public_text or _('This screen family is public (visible by the spectators).') %}
        {% elif object_type == 'rotator' %}
            {% set _tooltip_text=tooltip_public_text or _('This rotator is public (visible by the spectators).') %}
        {% elif object_type == 'display_controller' %}
            {% set _tooltip_text=tooltip_public_text or _('This display controller is public (visible by the spectators).') %}
        {% else %}
            {% set _tooltip_text=tooltip_public_text or '???' %}
        {% endif %}
        {% set _icon_class='bi-eye-fill text-success' %}
    {% else %}
        {% if object_type == 'event' %}
            {% set _tooltip_text=tooltip_private_text or _('This event is private (by default, screens are not visible by the spectators).') %}
        {% elif object_type == 'screen' %}
            {% set _tooltip_text=tooltip_private_text or _('This screen is private (not visible by the spectators).') %}
        {% elif object_type == 'family' %}
            {% set _tooltip_text=tooltip_private_text or _('This screen family is private (not visible by the spectators).') %}
        {% elif object_type == 'rotator' %}
            {% set _tooltip_text=tooltip_private_text or _('This rotator is private (not visible by the spectators).') %}
        {% elif object_type == 'display_controller' %}
            {% set _tooltip_text=tooltip_private_text or _('This display controller is private (not visible by the spectators).') %}
        {% else %}
            {% set _tooltip_text=tooltip_private_text or '???' %}
        {% endif %}
        {% set _icon_class='bi-eye-slash-fill text-danger' %}
    {% endif %}
    <span
            class="fw-bold {{ class }}"
            {{ tooltip_attributes('info', _tooltip_text, tooltip_placement or 'top') }}
        >
        <i class="{{ _icon_class }}"></i>
    </span>
    <!-- end visibility_icon() -->
{% endmacro %}

