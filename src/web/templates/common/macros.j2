
{% macro section_title() %}
    <div class="section-title">
        {{ caller() }}
    </div>
{% endmacro %}

{% macro tooltip_attributes(tooltip_type, tooltip_text, tooltip_placement='top') %}
    data-bs-toggle="tooltip"
    data-bs-placement="{{ tooltip_placement or 'top' }}"
    data-bs-html="true"
    data-bs-custom-class="{% if tooltip_type == 'error' %}sharly-chess-tooltip-error{% elif tooltip_type == 'warning' %}sharly-chess-tooltip-warning{% else %}sharly-chess-tooltip-info{% endif %}"
    data-bs-title="<i class='{% if tooltip_type == 'error' %}bi-exclamation-triangle-fill{% elif tooltip_type == 'warning' %}bi-exclamation-triangle{% elif tooltip_type == 'info' %}bi-info-circle-fill{% endif %}'></i> {{ tooltip_text }}"
    hx-on::before-send="$('body .tooltip').remove(); $('body .tooltip-inner').remove(); $('body .tooltip-arrow').remove();"
{% endmacro %}

{% macro point_adjustment_tooltip(tournament, team_id, round_) %}
{%- set manual = tournament.stored_point_adjustment(team_id, round_) -%}
{%- set rs = tournament.rule_set_point_adjustment(team_id, round_) -%}
{%- set lines = [] -%}
{%- if manual and (manual.mp_delta or manual.gp_delta) -%}
    {%- set parts = [] -%}
    {%- if manual.mp_delta -%}{%- set parts = parts + ['%+g'|format(manual.mp_delta) ~ ' ' ~ _('MP *** MATCH POINTS')] -%}{%- endif -%}
    {%- if manual.gp_delta -%}{%- set parts = parts + ['%+g'|format(manual.gp_delta) ~ ' ' ~ _('GP *** GAME POINTS')] -%}{%- endif -%}
    {%- set line = '<strong>' ~ parts|join(', ') ~ '</strong>' -%}
    {%- if manual.reason -%}{%- set line = line ~ ': ' ~ manual.reason -%}{%- endif -%}
    {%- set lines = lines + [line] -%}
{%- endif -%}
{%- if rs and (rs.mp or rs.gp) -%}
    {%- set parts = [] -%}
    {%- if rs.mp -%}{%- set parts = parts + ['%+g'|format(rs.mp) ~ ' ' ~ _('MP *** MATCH POINTS')] -%}{%- endif -%}
    {%- if rs.gp -%}{%- set parts = parts + ['%+g'|format(rs.gp) ~ ' ' ~ _('GP *** GAME POINTS')] -%}{%- endif -%}
    {%- set line = '<strong>' ~ parts|join(', ') ~ '</strong>' -%}
    {%- if rs.explanation -%}{%- set line = line ~ ': ' ~ rs.explanation -%}{%- endif -%}
    {%- set lines = lines + [line] -%}
{%- endif -%}
{{- lines|join('<br>') -}}
{% endmacro %}

{% macro click_to_copy_attributes(value, tooltip_placement='top', copied_value='', warning=false, wide=false) %}
    {{ tooltip_attributes(
        '',
        '<div class="fw-bold" '~ ('style="font-size:90%"' if wide else '') ~ '>' ~ value ~ '</div>'
        '<div class="fst-italic" style="font-size:90%">' ~ _('Click to copy') ~ '</div>',
        tooltip_placement
    ) }}
    onclick="navigator.clipboard.writeText(`{{ copied_value or value }}`)"
{% endmacro %}

