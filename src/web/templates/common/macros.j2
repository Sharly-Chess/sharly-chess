    ) }}?version={{ sharly_chess_config.version }}
{% endmacro %}

{% macro column_header(column) %}
    {% if column.header_template %}
        {% include column.header_template %}
    {% else %}
        {% set content = column.header_content %}
        {% if column.is_header_content_safe %}
            {{ content|safe }}
        {% else %}
            {{ content }}
        {% endif %}
    {% endif %}
{% endmacro %}

{% macro column_cell(column, object) %}
    {% set content = column.get_cell_content(object) %}
    {% if column.is_cell_content_safe %}
        {{ content|safe }}
    {% else %}
        {{ content }}
    {% endif %}
{% endmacro %}

{% macro column_footer(column, objects) %}
    {% if column.footer_template %}
        {% include column.footer_template %}
    {% else %}
        {% set content = column.get_footer_content(objects) %}
        {% if column.is_footer_content_safe %}
            {{ content|safe }}
        {% else %}
            {{ content }}
        {% endif %}
    {% endif %}
{% endmacro %}
