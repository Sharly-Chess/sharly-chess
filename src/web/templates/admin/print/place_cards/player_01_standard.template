type = "player"
name = "{{ _('Standard') }}"
creator = "Sharly Chess <support@sharly-chess.com>"

[player_name]
text = """"{{ player.federation_flag | safe }} <span translate="no">{{ player.title }} {{ player.full_name }}</span>"""
font_size = 18.0
bold = true
max_width = 92.0

[player_rating]
text = """{{ player.rating }}<span translate="no">{{ player.rating_type }}</span>"""
font_size = 18.0
bold = true
h_align = "right"

[player_origin]
text = """<span translate="no">{{ player.federation }} {% if player.club %}- {{ player.club }}{% endif %}</span>"""
v_pos = 8.0

[player_category]
text = "{{ player.category }}"
v_pos = 14.0

[event]
text = "{{ event.name }}"
italic = true
v_align = "bottom"
