{%
    from '../../common/macros.j2' import
    tooltip_attributes,
    visibility_icon
%}

{% macro family_visibility_icon(family, class) %}
    <!-- family_visibility_icon() -->
    {{ visibility_icon('family', family.public, '', '', class) }}
    <!-- end family_visibility_icon() -->
{% endmacro %}

{% macro tournament_status_icon(tournament, class) %}
    <!-- tournament_status_icon() -->
    {% if not tournament.started %}
        {% set _icon_class='bi-pause-fill' %}
        {% set _tooltip_text=_('The tournament has not yet started.') %}
    {% elif tournament.playing %}
        {% set _icon_class='bi-caret-right-square-fill' %}
        {% set _tooltip_text=_('Round #%(round)d is running.', round=tournament.current_round) %}
    {% elif not tournament.finished %}
        {% set _icon_class='bi-pause-fill' %}
        {% set _tooltip_text=_('Round #%(round)d is finished.', round=tournament.current_round) %}
    {% else %}
        {% set _icon_class='bi-check-circle-fill text-success' %}
        {% set _tooltip_text=_('The tournament is finished.') %}
    {% endif %}
    <span
            class="fw-bold {{ class }}"
            {% if _tooltip_text %}{{ tooltip_attributes('info', _tooltip_text, 'top') }}{% endif %}
        >
        <i class="{{ _icon_class }}"></i>
    </span>
    <!-- end tournament_status_icon() -->
{% endmacro %}

{% macro player_record(player) %}
    <!-- player_record() -->
    <div class="d-flex gap-1 h-100 align-items-center">
        {% for pairing in player.single_tournament_player.pairings.values() %}
            {% set _box_class='bg-white border border-white text-dark' if pairing.color == 'W' else 'bg-dark border border-white text-white' %}
            {% set _text_style='line-height: 0;' %}
            {% if pairing.zero_point_bye %}
                {% set _text='<i class="bi bi-0-circle-fill"></i>' %}
                {% set _class='text-secondary' %}
                {% set _tooltip_text=_('Zero-Point Bye') %}
            {% elif pairing.needs_pairing %}
                {% set _text='' %}
                {% set _class='text-secondary' %}
            {% elif pairing.paired_no_result %}
                {% set _text='&nbsp;' %}
                {% set _class=_box_class %}
            {% elif pairing.exempt %}
                {% set _text='+' %}
                {% set _text_style='position: relative; top: 0.1em;' %}
                {% set _tooltip_text=_('Pairing Allocated Bye') %}
            {% elif pairing.loss %}
                {% set _text='L' if pairing.unrated_loss else '0' %}
                {% set _class=_box_class  %}
                {% set _text_style='position: relative; top: 0.1em;' %}
                {% set _tooltip_text=_('Unrated Loss') if pairing.unrated_loss else _('Loss') %}
            {% elif pairing.draw %}
                {% set _text='D' if pairing.unrated_draw else '=' %}
                {% set _class=_box_class %}
                {% set _tooltip_text=_('Unrated Draw') if pairing.unrated_draw else _('Draw') %}
            {% elif pairing.win %}
                {% set _text='W' if pairing.unrated_gain else '1' %}
                {% set _class=_box_class %}
                {% set _text_style='position: relative; top: 0.1em;' %}
                {% set _tooltip_text=_('Unrated Win') if pairing.unrated_gain else _('Win') %}
            {% elif pairing.half_point_bye %}
                {% set _text='<i class="bi bi-circle-half"></i>' %}
                {% set _class='text-secondary' %}
                {% set _tooltip_text=_('Half-Point Bye') %}
            {% elif pairing.full_point_bye %}
                {% set _text='<i class="bi bi-1-circle-fill"></i>' %}
                {% set _class='text-secondary' %}
                {% set _tooltip_text=_('Full-Point Bye') %}
            {% elif pairing.forfeit_loss or pairing.double_forfeit %}
                {% set _text='-' %}
                {% set _class=_box_class %}
                {% set _tooltip_text=_('Forfeit Loss') %}
            {% elif pairing.forfeit_gain %}
                {% set _text='+' %}
                {% set _class=_box_class %}
                {% set _tooltip_text=_('Forfeit Win') %}
            {% else %}
                {% set _text='?' %}
                {% set _class='bg-danger text-white' %}
            {% endif %}
            <span
                class="player-record text-center p-0 m-0 {{ _class }}"
                {% if _tooltip_text %}
                    {{ tooltip_attributes('info', _tooltip_text) }}
                {% endif %}
                style="display: inline-flex; width: 1.5em; height: 1.5em; align-items: center; justify-content: center;"
            >
                <span style="{{ _text_style }}">
                    {{ _text|safe }}
                </span>
            </span>
        {% endfor %}
    </div>
    <!-- end player_record() -->
{% endmacro %}

{% macro admin_players_sort_link(url, icon, sort, admin_players_sort) %}
    <!-- admin_players_sort_link() -->
    {% if sort == 'alpha' %}
        {% set _tooltip_text=_('Sort the players by name.') %}
    {% elif sort == 'rating_desc' %}
        {% set _tooltip_text=_('Sort the players by rating (most rated first).') %}
    {% elif sort == 'rating_asc' %}
        {% set _tooltip_text=_('Sort the players by rating (less rated first).') %}
    {% elif sort == 'club' %}
        {% set _tooltip_text=_('Sort the players by club.') %}
    {% elif sort == 'yob_desc' %}
        {% set _tooltip_text=_('Sort the players by year of birth (youngest first).') %}
    {% elif sort == 'yob_asc' %}
        {% set _tooltip_text=_('Sort the players by year of birth (oldest first).') %}
    {% elif sort == 'tournament' %}
        {% set _tooltip_text=_('Sort the players by tournament.') %}
    {% else %}
        {% set _tooltip_text='Unknown sort [%(sort)s]'|format(sort=sort) %}
    {% endif %}
    <i
        class="{{ icon }} {% if admin_players_sort != sort %}cursor-pointer{% else %}text-danger{%endif %}"
        {% if admin_players_sort != sort %}
            hx-get="{{ url }}"
            hx-vals='{"admin_players_sort": "{{ sort }}"}'
            hx-target="body"
            hx-indicator="#please-wait"
        {% endif %}
        {{ tooltip_attributes('info', _tooltip_text, 'top') }}
    ></i>
    <!-- end admin_players_sort_link() -->
{% endmacro %}

{% macro _select_option(value, text_or_option, selected) %}
    {% if text_or_option is string %}
        <option value="{{ value }}" {% if selected %}selected{% endif %}>
            {{ text_or_option }}
        </option>
    {% else %}
        {# An option of type SelectOption has been passed #}
        {% set option = text_or_option %}
        <option
            class="{{ option.classes }}"
            data-class="{{ option.classes }}"
            value="{{ value }}"
            {% if option.tooltip %}
                title="{{ option.tooltip }}"
            {% endif %}
            {% if option.search %}
                data-search="{{ option.search }}"
            {% endif %}
            {% if option.subtitle %}
                data-subtitle="{{ option.subtitle }}"
            {% endif %}
            {% if option.disabled %}disabled{% endif %}
            {% if selected %}selected{% endif %}
        >
            {{ option.name }}
        </option>
    {% endif %}
{% endmacro %}

{% macro select_content(
    id,
    name,
    options,
    selected=[],
    disabled=false,
    multiple=false,
    placeholder='',
    multiple_select_all=false,
    error=false,
    tooltip_select=false,
    search_disabled=false,
    search_placeholder='',
    onchange=''
) %}
    <select
        name="{{ name }}"
        id="{{ id }}"
        data-testid="{{ id }}"
        class="form-select sharly-chess-select2 {% if error %}is-invalid{% endif %}"
        aria-describedby="{{ id }}-help {{ id }}-error"
        {% if disabled or (options|length <= 1 and not multiple) %}
            disabled
        {% endif %}
        {% if multiple %}
            multiple
            {% if placeholder %}
                data-placeholder='{{ placeholder }}'
            {% endif %}
        {% endif %}
        style="display:none"
        {% if onchange %}
            onchange="{{ onchange }}"
        {% endif %}
    >
        {% if placeholder and not multiple %}
            <option
                value="__placeholder__"
                class="opacity-75"
                data-class="opacity-75"
            >
                {{ placeholder }}
            </option>
        {% endif %}
        {% if multiple_select_all %}
            <option value="__all__">
                {{ _('Select All') }}
            </option>
            <option value="__divider__" disabled></option>
        {% endif %}
        {% for key, text_or_option_or_options in options.items() %}
            {% if text_or_option_or_options is mapping %}
                <optgroup label="{{ key }}">
                    {% for value, text_or_option in text_or_option_or_options.items() %}
                        {{ _select_option(value, text_or_option, value in selected) }}
                    {% endfor %}
                </optgroup>
            {% else %}
                {{ _select_option(key, text_or_option_or_options, key in selected) }}
            {% endif %}
        {% endfor %}
    </select>
    {% set keep_open_on_select = multiple %}
    <script>
        {% if tooltip_select %}
            var oldParams = '';
        {% endif %}
        $('#{{ id }}').select2({
            theme: 'bootstrap-5',
            width: '100%',
            placeholder: $(this).data('placeholder'),
            language: {
                noResults: function() {
                    return `{{ _('No results.') }}`;
                },
            },
            minimumResultsForSearch: {% if search_disabled %}1000{% elif search_placeholder %}5{% else %}10{% endif %},
            dropdownParent: $('#modal-wrapper'),
            closeOnSelect: {% if keep_open_on_select %}false{% else %}true{% endif %},
            templateResult: function (data) {
                if (data.id === '__divider__') {
                    const $div = $('<span style="pointer-events: none; border-bottom: 1px solid #ccc; display: block; margin: 4px 0;"></span>');
                    return $div;
                }
                const $result = $('<span>' + data.text + '</span>');
                const tooltip = $(data.element).attr('data-bs-title');
                if (tooltip) $result.attr('data-bs-title', tooltip);
                const subtitle = $(data.element).attr('data-subtitle');
                if (subtitle) {
                    $result.append($(
                        '<div class="fst-italic" style="font-size: 70%">' + subtitle + '</div>'
                    ));
                }
                const optionClass = $(data.element).data('class');
                if (optionClass) $result.addClass(optionClass);
                const search = $(data.element).data('search');
                if (search) $result.attr('data-search', search);
                return $result;
            },
            templateSelection: function (data) {
                const $result = $('<span>' + data.text + '</span>');
                const optionClass = $(data.element).data('class');
                if (optionClass) $result.addClass(optionClass);
                return $result;
            },
            matcher: function(params, data) {
                {% if tooltip_select %}
                    if(params !== oldParams) {
                        $('[role="tooltip"]').remove();
                        oldParams = params;
                    }
                {% endif %}
                if(data.element.tagName === 'OPTGROUP') {
                    return $.fn.select2.defaults.defaults.matcher(params, data);
                }
                if ($.trim(params.term) === '') return data;
                const searchTerm = normalizeText(params.term);
                if (
                    typeof data.text !== 'undefined' &&
                    normalizeText(data.text).indexOf(searchTerm) > -1
                ) {
                    return data;
                }
                const search = $(data.element).data('search');
                if (search && normalizeText(search).indexOf(searchTerm) > -1) {
                    return data;
                }
                return null;
            },
        });
        {% if search_placeholder %}
            $('#{{ id }}').one('select2:open', () => {
                $('.select2-search__field[aria-controls="select2-{{ id }}-results"]').prop(
                    'placeholder', `{{ search_placeholder }}`
                );
            });
        {% endif %}
        // Width changes dynamically on load, needs to be reset to display the placeholder nicely
        $('.select2-search__field').css('width', '100%');
        $('#{{ id }}').on('select2:select', function (e) {
            if (e.params.data.id === '__all__') {
                const allValues = $('#{{ id }}').find('option')
                    .map(function () {
                        const val = $(this).val();
                        return val !== '__all__' && val !== '__divider__' ? val : null;
                    })
                    .get();
                $('#{{ id }}').val(allValues).trigger('change');
            }
        });
        $('#{{ id }}').on('select2:closing', function (e) {
            if ($('.modal.show').length > 0) {
                ignoreNextModalClose = true;
                setTimeout(function(){
                    ignoreNextModalClose = false;
                }, 500);
            }
        });
        {% if tooltip_select %}
            $('#{{ id }}').on('select2:close', function(e) {
                $('[role="tooltip"]').remove();
            });
            $('body').tooltip({
                selector: '[data-bs-toggle="tooltip"],.select2-results__option',
                title: function() {
                    return $(this).prev().attr("data-bs-title");
                },
                placement: "right",
                container: "#modal-wrapper",
                html: true,
                zIndex: 10010,
                template: '<div class="tooltip" role="tooltip"><div class="tooltip-arrow"></div><div class="tooltip-inner {{ id }}"></div></div>',
                // delay: { "show": 0, "hide": 1000000000 }
            });
        {% endif %}
        {% if keep_open_on_select %}
            // Prevent closing the dropdown when an option is deselected
            $('#{{ id }}').on('select2:unselecting', function(e) {
                e.preventDefault();

                const unselectedData = e.params.args.data;
                const $select = $(this);
                const selectedValues = $select.val() || [];
                const updatedValues = selectedValues.filter(val => val !== unselectedData.id);

                $dropdownOption = $(`.select2-results__option[aria-selected="true"]:contains("${unselectedData.text}")`);
                $dropdownOption.attr('aria-selected', 'false');
                $dropdownOption.removeClass('select2-results__option--highlighted');

                $select.val(updatedValues).trigger('change');
                $select.trigger('select2:unselect');
            });
        {% endif %}
    </script>
    {% if options|length == 1 and not disabled and not multiple %}
        <input type="hidden" name="{{ name }}" value="{{ options|list|first }}" />
    {% endif %}
{% endmacro %}

{% macro set_date_picker(
    id,
    input_type='date',
    min_date='',
    max_date='',
    on_hide='',
    now_button=false,
    disabled_dates=[],
    position=''
) %}
    <span id="{{ id }}-datepicker-container"></span>
    {% set formatter = sharly_chess_config.date_formatter %}
    <script>
        datePickers['{{ id }}'] = new AirDatepicker('#{{ id }}', {
            classes: 'dark',
            dateFormat: `{{ formatter.air_date_picker_format }}`,
            timeFormat: 'HH:mm',
            firstDay: 1,
            container: document.getElementById('{{ id }}-datepicker-container'),
            keyboardNav: false,
            {% if position %}
                position: '{{ position }}',
            {% endif %}
            {% if min_date %}
                minDate: ({{ formatter.value_to_date_js_function|safe }})(`{{ min_date }} 00:00`),
            {% endif %}
            {% if max_date %}
                maxDate: ({{ formatter.value_to_date_js_function|safe }})(`{{ max_date }} 23:59`),
            {% endif %}
            {% if input_type == 'date-range' %}
                range: true,
                multipleDatesSeparator: '{{ formatter.range_separator }}',
            {% elif input_type == 'datetime' %}
                timepicker: true,
                minutesStep: 5,
                startDate: (
                    {% if min_date or max_date %}
                        ({{ formatter.value_to_date_js_function|safe }})(`{{ min_date or max_date }} 00:00`)
                    {% else %}
                        new Date(new Date().setHours(0, 0, 0, 0))
                    {% endif %}
                ),
                {% if min_date and max_date %}
                    {# Selecting first using the time picker uses the current date, prevent selection if it's outside the time range #}
                    onBeforeSelect: ({date, datepicker}) => {
                        const minDate = ({{ formatter.value_to_date_js_function|safe }})(`{{ min_date }} 00:00`);
                        const maxDate = ({{ formatter.value_to_date_js_function|safe }})(`{{ max_date }} 23:59`);
                        return date >= minDate && date <= maxDate;
                    },
                {% endif %}
            {% endif %}
            {% if now_button %}
                buttons: [
                    {
                        content(dp) { return `{{ _('Now') }}`; },
                        onClick(dp) { dp.selectDate(new Date(), {updateTime: true}); }
                    }
                ],
            {% endif %}
            {% if disabled_dates %}
                onRenderCell: ({date}) => {
                    const disabledDates = [
                        {% for date in disabled_dates %}
                            `{{ formatter.date_str_to_iso_format(date) }}`,
                        {% endfor %}
                    ];
                    if (disabledDates.includes(formatISODate(date))) {
                        return {disabled: true};
                    }
                },
            {% endif %}
            {% if on_hide %}
                onHide: (isFinished) => {
                    if (isFinished) {
                        {{ on_hide|safe }}
                    }
                },
            {% endif %}
            locale: {
                daysMin: [
                    "{{ _('Su *** SUNDAY') }}",
                    "{{ _('Mo *** MONDAY') }}",
                    "{{ _('Tu *** TUESDAY') }}",
                    "{{ _('We *** WEDNESDAY') }}",
                    "{{ _('Th *** THURSDAY') }}",
                    "{{ _('Fr *** FRIDAY') }}",
                    "{{ _('Sa *** SATURDAY') }}",
                ],
                months: [
                    "{{ _('January') }}",
                    "{{ _('February') }}",
                    "{{ _('March') }}",
                    "{{ _('April') }}",
                    "{{ _('May') }}",
                    "{{ _('June') }}",
                    "{{ _('July') }}",
                    "{{ _('August') }}",
                    "{{ _('September') }}",
                    "{{ _('October') }}",
                    "{{ _('November') }}",
                    "{{ _('December') }}"
                ],
                monthsShort: [
                    "{{ _('Jan *** JANUARY') }}",
                    "{{ _('Feb *** FEBRUARY') }}",
                    "{{ _('Mar *** MARCH') }}",
                    "{{ _('Apr *** APRIL') }}",
                    "{{ _('May *** MAY ACRONYM') }}",
                    "{{ _('Jun *** JUNE') }}",
                    "{{ _('Jul *** JULY') }}",
                    "{{ _('Aug *** AUGUST') }}",
                    "{{ _('Sep *** SEPTEMBER') }}",
                    "{{ _('Oct *** OCTOBER') }}",
                    "{{ _('Nov *** NOVEMBER') }}",
                    "{{ _('Dec *** DECEMBER') }}"
                ],
            },
        });
        $('#{{ id }}').on('keyup', function () {
            const selected = getAirDatePickerSelectedDates(
                value=$(this).val(),
                inputType='{{ input_type }}',
                rangeSeparator=`{{ formatter.range_separator }}`,
                valueToDate={{ formatter.value_to_date_js_function|safe }},
                dateRegex=/{{ formatter.regex }}/,
                datetimeRegex=/{{ formatter.datetime_regex }}/,
            );
            if (selected.length === 0) return;
            const picker = datePickers['{{ id }}'];
            if (picker.minDate && !selected.every(date => date >= picker.minDate)) return;
            if (picker.maxDate && !selected.every(date => date <= picker.maxDate)) return;
            picker.selectDate(selected, {updateTime: true});
        });
         $('#{{ id }}').trigger('keyup');
    </script>
{% endmacro %}

