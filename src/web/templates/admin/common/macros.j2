{%
    from '../../common/macros.j2' import
    tooltip_attributes,
    visibility_icon
%}

{% macro family_visibility_icon(family, class) %}
    <!-- family_visibility_icon() -->
    {{ visibility_icon('family', family.public, '', '', class) }}
    <!-- end family_visibility_icon() -->
{% endmacro %}

{% macro tournament_status_icon(tournament, class) %}
    <!-- tournament_status_icon() -->
    {% if not tournament.rounds %}
        {% set _icon_class='bi-exclamation-triangle-fill text-danger' %}
        {% set _tooltip_text='' %}
    {% elif not tournament.started %}
        {% set _icon_class='bi-pause-fill' %}
        {% set _tooltip_text=_('The tournament is not started yet.') %}
    {% elif tournament.playing %}
        {% set _icon_class='bi-caret-right-square-fill' %}
        {% set _tooltip_text=_('Round #%(round)d is running.', round=tournament.current_round) %}
    {% elif not tournament.finished %}
        {% set _icon_class='bi-pause-fill' %}
        {% set _tooltip_text=_('Round #%(round)d is finished.', round=tournament.current_round) %}
    {% else %}
        {% set _icon_class='bi-check-circle-fill text-success' %}
        {% set _tooltip_text=_('The tournament is finished.') %}
    {% endif %}
    <span
            class="fw-bold {{ class }}"
            {% if _tooltip_text %}{{ tooltip_attributes('info', _tooltip_text, 'top') }}{% endif %}
        >
        <i class="{{ _icon_class }}"></i>
    </span>
    <!-- end tournament_status_icon() -->
{% endmacro %}

{% macro player_record(player) %}
    <!-- player_record() -->
    {% for pairing in player.pairings.values() %}
        {% if pairing.zero_point_bye %}
            {% set _text='f' %}
            {% set _class='text-secondary' %}
        {% elif pairing.not_paired %}
            {% set _text='' %}
            {% set _class='text-secondary' %}
        {% elif pairing.playing %}
            {% set _text='&nbsp;' %}
            {% set _class='bg-white border border-dark text-dark' if pairing.color == 'W' else 'bg-dark border border-white text-white' %}
        {% elif pairing.exempt %}
            {% set _text='x' %}
            {% set _class='text-secondary' %}
        {% elif pairing.loss %}
            {% set _text='-' %}
            {% set _class='bg-white border border-dark text-dark' if pairing.color == 'W' else 'bg-dark border border-white text-white' %}
        {% elif pairing.draw %}
            {% set _text='=' %}
            {% set _class='bg-white border border-dark text-dark' if pairing.color == 'W' else 'bg-dark border border-white text-white' %}
        {% elif pairing.gain %}
            {% set _text='+' %}
            {% set _class='bg-white border border-dark text-dark' if pairing.color == 'W' else 'bg-dark border border-white text-white' %}
        {% elif pairing.half_point_bye %}
            {% set _text='=' %}
            {% set _class='text-secondary' %}
        {% elif pairing.full_point_bye %}
            {% set _text='+' %}
            {% set _class='text-secondary' %}
        {% elif pairing.forfeit_loss or pairing.double_forfeit %}
            {% set _text='<' %}
            {% set _class='text-secondary' %}
        {% elif pairing.forfeit_gain %}
            {% set _text='>' %}
            {% set _class='text-secondary' %}
        {% else %}
            {% set _text='?' %}
            {% set _class='bg-danger text-white' %}
        {% endif %}
        <span
                class="player-record text-center p-0 m-0  {{ _class }}"
                {% if tooltip_placement %}
                    {{ tooltip_attributes(_tooltip_level, _tooltip_text, tooltip_placement) }}
                {% endif %}
                style="display: inline-block; width: 1em"
        >
            {{ _text|safe }}
        </span>
    {% endfor %}
    <!-- end player_record() -->
{% endmacro %}

{% macro admin_players_sort_link(url, icon, sort, admin_players_sort) %}
    <!-- admin_players_sort_link() -->
    {% if sort == 'alpha' %}
        {% set _tooltip_text=_('Sort the players by name.') %}
    {% elif sort == 'rating_desc' %}
        {% set _tooltip_text=_('Sort the players by rating (most rated first).') %}
    {% elif sort == 'rating_asc' %}
        {% set _tooltip_text=_('Sort the players by rating (less rated first).') %}
    {% elif sort == 'club' %}
        {% set _tooltip_text=_('Sort the players by club.') %}
    {% elif sort == 'yob_desc' %}
        {% set _tooltip_text=_('Sort the players by year of birth (youngest first).') %}
    {% elif sort == 'yob_asc' %}
        {% set _tooltip_text=_('Sort the players by year of birth (oldest first).') %}
    {% elif sort == 'category_desc' %}
        {% set _tooltip_text=_('Sort the players by category (oldest first).') %}
    {% elif sort == 'category_asc' %}
        {% set _tooltip_text=_('Sort the players by category (youngest first).') %}
    {% elif sort == 'tournament' %}
        {% set _tooltip_text=_('Sort the players by tournament.') %}
    {% else %}
        {% set _tooltip_text='Unknown sort [%(sort)s]'|format(sort=sort) %}
    {% endif %}
    <i
        class="{{ icon }} {% if admin_players_sort != sort %}cursor-pointer{% else %}text-danger{%endif %}"
        {% if admin_players_sort != sort %}
            hx-get="{{ url }}"
            hx-vals='{"admin_players_sort": "{{ sort }}"}'
            preload
            hx-target="body"
            hx-indicator="#please-wait"
        {% endif %}
        {{ tooltip_attributes('info', _tooltip_text, 'top') }}
    ></i>
    <!-- end admin_players_sort_link() -->
{% endmacro %}

{% macro gender_icon(gender) %}
    <!-- gender_icon() -->
    {% if gender.value == 0 %}
        {% set _icon_class='-' %}
    {% elif gender.value == 1 %}
        {% set _icon_class='bi-person-standing-dress' %}
    {% elif gender.value == 2 %}
        {% set _icon_class='bi-person-standing' %}
    {% else %}
        {% set _icon_class='bi-question' %}
    {% endif %}
    {% if _icon_class %}<i class="{{ _icon_class }}"></i>{% endif %}
    <!-- end gender_icon() -->
{% endmacro %}

{#
name: used by the query parameter
input_type: see *_input() below
label: the form label of the field
placeholder: the text inside text inputs when empty, also used as the text for the switches
help_text: the text printed below the input
data, errors: used to pre-fill the inputs and error messages (data[name] and errors[name] are used for this field)
error: if true, sets the field as "on error", event if errors[name] is not set
default_checkbox: if true, a checkbox is printed with the default message "by default", with query name <name>_checkbox
default_checkbox_text: another message to replace "by default"
default_value: the value to be set when the default checkbox is checked
select_options: a dict[str, str], keys are the select values and values are the select texts
number_min: the minimum value for numbers
number_max: the maximum value for numbers
number_step: the step value for numbers
disabled: if set to true, the field will be disabled
hx_get: the hx-get attribute of the input, optional
hx_target: the hx-target attribute of the input, optional
hx_indicator_img: the URL of the image of the indicator, optional
hx_on_before_request: the JS to run before the HTMX request (text inputs only)
hx_on_after_request: the JS to run after the HTMX request (text inputs only)
#}

{% macro _generic_input(
    name,
    input_type,
    label='NO LABEL',
    placeholder='',
    help_text='NO HELP TEXT',
    data={},
    errors={},
    error=false,
    valid=false,
    password_visible=false,
    default_checkbox=false,
    default_checkbox_text='',
    default_value='',
    select_options={},
    number_min='',
    number_max='',
    number_step='',
    disabled=false,
    hx_get='',
    hx_post='',
    hx_target='',
    hx_indicator='',
    hx_indicator_img='',
    hx_trigger='',
    hx_include='',
    hx_swap='',
    hx_on_before_request='',
    hx_on_after_request='',
    hx_sync='',
    hx_vals=''
) %}
    <!-- {{ input_type }}_input({{ name }}) -->
        {% set id=name|replace('_', '-') %}
        {% set default_checkbox_name=name~'_checkbox' %}
        {% set default_checkbox_id=default_checkbox_name|replace('_', '-') %}
        {% if default_checkbox and data[default_checkbox_name] == 'on' %}
            {% set value=default_value %}
        {% else %}
            {% set value=data[name] %}
        {% endif %}
        <div class="input-block">
            <div class="d-flex align-items-center">
                {% if label %}
                    <label
                        for="{{ id }}"
                        class="form-check-label flex-grow-1 mb-1"
                    >
                        {{ label }}
                    </label>
                {% endif %}
                {% if default_checkbox %}
                    {{ default_checkbox_text or _('by default') }}
                    <input
                        id="{{ default_checkbox_id }}"
                        name="{{ default_checkbox_name }}"
                        type="checkbox"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        {% if data[default_checkbox_name] == 'on' %}checked{% endif %}
                        class="ms-2"
                    />
                {% endif %}
            </div>

            <div
                class="
                    pw-input-group
                    {% if input_type == 'password' %}input-group{% endif %}
                    {% if hx_indicator_img %}d-flex align-items-center{% endif %}
                    {% if input_type == 'switch' %}form-check form-switch d-inline-block pe-3{% endif %}
                "
            >
                {% if input_type == 'select' %}
                    <select
                        name="{{ name }}"
                        id="{{ id }}"
                        class="form-select {% if error or (name in errors) %}is-invalid{% endif %}"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        {% if disabled or select_options|length <= 1 %}
                            disabled
                        {% endif %}
                    >
                        {% for value, text in select_options.items() %}
                            <option value="{{ value }}" {% if value == data[name] %}selected{%endif %}>
                                {{ text }}
                            </option>
                        {% endfor %}
                    </select>
                    {% if select_options|length == 1 %}
                        <input type="hidden" name="{{ name }}" value="{{ data[name] }}" />
                    {% endif %}
                {% elif input_type == 'switch' %}
                    <input
                        id="{{ id }}"
                        name="{{ name }}"
                        type="checkbox"
                        class="form-check-input"
                        value="on"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        {% if data[name] == 'on' %}checked{% endif %}
                        {% if disabled %}
                            disabled
                        {% endif %}
                    />
                    {{ placeholder }}
                {% else %}
                    {% if disabled %}
                        <input
                            id="{{ id }}"
                            name="{{ name }}"
                            type="hidden"
                            value="{{ value }}"
                        />
                    {% endif %}
                    <input
                        id="{{ id }}"
                        name="{{ name }}"
                        type="{{ input_type if not password_visible else 'text' }}"
                        {% if number_min != '' %}
                            min="{{ number_min }}"
                        {% endif %}
                        {% if number_max != '' %}
                            max="{{ number_max }}"
                        {% endif %}
                        {% if number_step != '' %}
                            step="{{ number_step }}"
                        {% endif %}
                        class="form-control {% if error or (name in errors) %}is-invalid{% endif %} {% if valid %}is-valid{% endif %}"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        placeholder="{{ placeholder }}"
                        value="{{ value }}"
                        {% if disabled or (default_checkbox and data[default_checkbox_name] == 'on') %}disabled{% endif %}
                        {% if hx_get %}
                            hx-get="{{ hx_get }}"
                        {% endif %}
                        {% if hx_post %}
                            hx-post="{{ hx_post }}"
                        {% endif %}
                        {% if hx_target %}
                            hx-target="{{ hx_target }}"
                        {% endif %}
                        {% if hx_indicator %}
                            hx-indicator="{{ hx_indicator }}"
                        {% endif %}
                        {% if hx_indicator_img %}
                            hx-indicator="#{{ id }}_indicator"
                        {% endif %}
                        {% if hx_trigger %}
                            hx-trigger="{{ hx_trigger }}"
                        {% endif %}
                        {% if hx_swap %}
                            hx-swap="{{ hx_swap }}"
                        {% endif %}
                        {% if hx_include %}
                            hx-include="{{ hx_include }}"
                        {% endif %}
                        {% if hx_on_before_request %}
                            hx-on::before-request="{{ hx_on_before_request }}"
                        {% endif %}
                        {% if hx_on_after_request %}
                            hx-on::after-request="{{ hx_on_after_request }}"
                        {% endif %}
                        {% if hx_sync %}
                            hx-sync="{{ hx_sync }}"
                        {% endif %}
                        {% if hx_vals %}
                            hx-vals="{{ hx_vals }}"
                        {% endif %}
                    />
                    {% if input_type == 'password' %}
                        <i
                            id="{{ id }}-toggle-password"
                            class="input-group-text {{ 'bi-eye-slash-fill' if not password_visible else 'bi-eye-fill' }} ps-2 pt-2 cursor-pointer {% if name in errors %}is-invalid{% endif %} {% if valid %}is-valid{% endif %}"
                        ></i>
                    {% endif %}
                    {% if hx_indicator_img %}
                        <img
                            id="{{ id }}_indicator"
                            class="htmx-indicator"
                            src="{{ hx_indicator_img }}"
                            style="height: 1.5em; margin-left: -40px; z-index: 3;"
                        />
                    {% endif %}
                {% endif %}
            </div>
            {% if help_text %}
                <div id="{{ id }}-help" class="form-text">
                    {{ help_text }}
                </div>
            {% endif %}
            {% if name in errors %}
                <div id="{{ id }}-error" class="form-text invalid-feedback">
                    {{ errors[name] }}
                </div>
            {% endif %}
        </div>
        {% if input_type == 'password' %}
            <script>
                $('#{{ id }}-toggle-password').on('click', function(event) {
                    event.preventDefault();
                    hide = $('#{{ id }}').attr("type") == 'text'
                    $('#{{ id }}').attr('type', hide ? 'password' : 'text');
                    $('#{{ id }}-toggle-password').addClass(hide ? 'bi-eye-slash-fill' : 'bi-eye-fill');
                    $('#{{ id }}-toggle-password').removeClass(hide ? 'bi-eye-fill' : 'bi-eye-slash-fill');
                });
            </script>
        {% endif %}
        {% if default_checkbox %}
            <script>
                $('#{{ default_checkbox_id }}').click(function() {
                    if ($(this).is(':checked')) {
                        $('#{{ id }}').val('{{ default_value }}');
                        $('#{{ id }}').prop('disabled', true);
                    } else {
                        $('#{{ id }}').prop('disabled', false);
                    }
                });
            </script>
        {% endif %}
    <!-- end {{ input_type }}_input({{ name }}) -->
{% endmacro %}

