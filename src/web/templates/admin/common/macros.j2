{% macro plugin_switch_input(
    plugin,
    data,
    used_message='',
    disabled=false,
    default_state=false
) %}
    <div class="input-block position-relative">
        <div class="pw-input-group form-check form-switch d-inline-block pe-3">
            <span {% if used_message %}{{ macros.tooltip_attributes('info', used_message, 'top') }}{% endif %}>
                <input
                    id="{{ plugin.form_key }}"
                    name="{{ plugin.form_key }}"
                    data-testid="{{ plugin.form_key }}"
                    type="checkbox"
                    class="form-check-input plugin-switch-input"
                    value="on"
                    data-dependencies="{{ ';'.join(plugin.dependency_form_keys) }}"
                    data-used="{{ 'true' if used_message else 'false' }}"
                    data-user-state="undefined"
                    data-default-state="{{ 'true' if default_state else 'false' }}"
                    {% if used_message or data[plugin.form_key] == 'on' %}
                        checked
                    {% endif %}
                    {% if used_message or disabled %}
                        disabled
                    {% endif %}
                >
                {{ plugin.name }}
            </span>
            {% if used_message %}
                <input
                    name="{{ plugin.form_key }}"
                    type="hidden"
                    value="on"
                >
            {% endif %}
            <i
                class="bi bi-info-circle-fill ms-2"
                {{ macros.tooltip_attributes('', plugin.description, 'top') }}
            ></i>
            {% for required_by_plugin in plugin.required_by_plugins %}
                <i
                    id="{{ plugin.form_key }}-{{ required_by_plugin.form_key }}-dependency"
                    class="bi-lock-fill text-primary {{ plugin.form_key }}-dependency"
                    {{ macros.tooltip_attributes(
                        '', _('Required by plugin <b>%(plugin)s</b>.', plugin=required_by_plugin.name), 'top'
                    ) }}
                    style="display:none"
                ></i>
            {% endfor %}
        </div>
        <script>
            $('#{{ plugin.form_key }}').change(function (event, save_user_state=true) {
                if (save_user_state) $(this).attr('data-user-state', this.checked);
                this.dataset.dependencies.split(';').forEach((dependency) => {
                    if (!dependency) return;
                    const dependencyElement = $('#' + dependency);
                    if(this.checked) {
                        $('#' + dependency + '-{{ plugin.form_key }}-dependency').show();
                        dependencyElement.prop('checked', true);
                        dependencyElement.prop('disabled', true);
                        dependencyElement.trigger('change', [false]);
                    } else {
                        $('#' + dependency + '-{{ plugin.form_key }}-dependency').hide();
                        if (
                            dependencyElement.attr('data-used') !== 'true'
                            && !$('.' + dependency + '-dependency:visible').length
                        ) {
                            dependencyElement.prop('disabled', false);
                            const userState = dependencyElement.attr('data-user-state');
                            const defaultState = dependencyElement.attr('data-default-state');
                            if (userState === 'false' || (
                                userState === 'undefined' && defaultState === 'false'
                            )) {
                                dependencyElement.prop('checked', false);
                                dependencyElement.trigger('change', [false]);
                            }
                        }
                    }
                });
            });
        </script>
    </div>
{% endmacro %}

