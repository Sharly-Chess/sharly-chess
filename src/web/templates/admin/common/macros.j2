{% macro inline_text_form(
    id,
    name,
    value='',
    placeholder='NO PLACEHOLDER',
    post_url='',
    patch_url=''
) %}
    <form
        id="{{ id }}-form"
        class="input-group"
        {% if post_url %}
            hx-post="{{ post_url }}"
        {% elif patch_url %}
            hx-patch="{{ patch_url }}""
        {% endif %}
        hx-target="body"
        hx-indicator="#please-wait"
    >
        <input
            id="{{ id }}-input"
            data-testid="{{ id }}-input"
            name="{{ name }}"
            type="text"
            class="form-control"
            placeholder="{{ placeholder }}"
            value="{{ value }}"
            style="outline-offset: 0px;"
        >
        <span
            id="{{ id }}-submit-button-container"
            {{ macros.tooltip_attributes('', _('Validate'), 'top') }}
        >
            <button
                id="{{ id }}-submit-button"
                data-testid="{{ id }}-submit-button"
                class="btn btn-primary rounded-0"
                type="submit"
                {% if not value %}disabled{% endif %}
                style="outline-offset: 0px;"
            >
                <i class="bi-check"></i>
            </button>
        </span>
        <button
            id="{{ id }}-cancel-button"
            data-testid="{{ id }}-cancel-button"
            class="inline-form-cancel-button btn btn-secondary"
            type="button"
            style="outline-offset: 0px;"
            {{ macros.tooltip_attributes('', _('Cancel'), 'top') }}
        >
            <i class="bi-x"></i>
        </button>
    </form>
    <script>
        $('#{{ id }}-input').focus(function() {
            $('#{{ id }}-form').addClass('focus');
        });
    </script>
{% endmacro %}

{% macro toggle_input(
    name,
    label_on='ON',
    label_off='OFF',
    hx_patch='',
    size='sm',
    checked=false,
    disabled=false
) %}
    {% set id=name|replace('_', '-') %}
    <input
        id="{{ id }}"
        name="{{ name }}"
        type="checkbox"
        {% if hx_patch %}
            hx-patch="{{ hx_patch }}"
            hx-trigger="change delay:300ms"
        {% endif %}
        data-onlabel="{{ label_on }}"
        data-offlabel="{{ label_off }}"
        data-toggle="toggle"
        data-size="{{ size }}"
        {% if size == 'xs' %}
            data-height="20"
        {% endif %}
        data-style="rounded"
        {% if checked %}checked{% endif %}
        {% if disabled %}disabled{% endif %}
        {{ macros.tooltip_attributes('', 'test') }}
    >
    <script>
       $('#{{ id }}').bootstrapToggle();
    </script>
{% endmacro %}

{% macro radio_input(
    name,
    label_by_value,
    tooltip_by_value,
    selected=''
) %}
    {% set radio_id=name|replace('_', '-') %}
    {% for value, label in label_by_value.items() %}
        {% set id = radio_id ~ '-' ~ value %}
        <div class="form-check">
            <input
                id="{{ id }}"
                class="form-check-input"
                type="radio"
                name="{{ name }}"
                value="{{ value }}"
                {% if value == selected %}
                    checked
                {% endif %}
            >
            <label class="form-check-label" for="{{ id }}">
                {{ label }}
                {% if value in tooltip_by_value %}
                    <i
                        class="bi-info-circle-fill ps-1"
                        style="font-size: 90%"
                        {{ macros.tooltip_attributes('', tooltip_by_value[value]) }}
                    ></i>
                {% endif %}
            </label>
        </div>

    {% endfor %}
{% endmacro %}

{% macro uniq_id_form(
    current_uniq_id,
    existing_uniq_ids=[],
    placeholder='',
    patch_url=''
) %}
    {% set id = 'uniq-id-update' %}
    {{ inline_text_form(
        id,
        name='uniq_id',
        placeholder=placeholder,
        value=current_uniq_id,
        patch_url=patch_url,
    ) }}
    <script>
        $('#{{ id }}-input').on('input', function() {
            let error = "";
            const value = $(this).val();
            if (value === '') {
                error = "{{ _('A value is expected.') }}";
            } else if (value != "{{ current_uniq_id }}" && {{ existing_uniq_ids|tojson }}.includes(value)) {
                error = "{{ _('This unique ID is already used.') }}";
            } else if (!value.match(/^[0-9a-zA-Z_\-]+$/)) {
                error = "{{ _('Accepted characters are letters, numbers, underscore (_) and minus (-).') }}";
            }

            $('#{{ id }}-submit-button').prop('disabled', error !== "");
            const tooltipElement = document.getElementById('{{ id }}-submit-button-container');
            const tooltip = bootstrap.Tooltip.getInstance(tooltipElement);
            tooltip.setContent({ '.tooltip-inner': error || "{{ _('Validate') }}" });
            tooltip.update();
        });
    </script>
{% endmacro %}

{% macro inline_multi_select_form(
    id,
    name,
    options,
    selected=[],
    placeholder='',
    post_url='',
    hx_target='',
    tooltip_select=false
) %}
    <form
        hx-post="{{ post_url }}"
        hx-target="{{ hx_target }}"
        hx-indicator="#please-wait"
        hx-swap="outerHTML"
    >
        <input id="{{ id }}-form-value" name="{{ name }}" type="hidden">
        <button id="{{ id }}-form-submit" type="submit" style="display:none"></button>
    </form>
    <div id="{{ id }}-select-container" class="input-group" style="flex-wrap: nowrap !important;">
        {{ select_content(
            id=id ~ '-select',
            name='',
            options=options,
            selected=selected,
            multiple=true,
            placeholder=placeholder,
            tooltip_select=tooltip_select,
        ) }}
        <script>
            $('#{{ id }}-select').on('select2:selecting', function(e) {
                const selectedValue = e.params.args.data.id;

                // Submit the form with the selected value
                $('#{{ id }}-form-value').val(selectedValue);
                $('#{{ id }}-form-submit').click();

                // Increment the counter in the option text
                const $option = $(`.select2-results__option[data-select2-id$=-${selectedValue}]`);
                const selectedText = $option.text();
                const counterMatch = selectedText.match(/\(x(\d+)\)/);
                let newText = '';
                if (counterMatch) {
                    const counter = parseInt(counterMatch[1]) + 1;
                    newText = selectedText.replace(/\(x\d+\)/, `(x${counter})`);
                } else {
                    newText = selectedText + ' (x1)';
                }
                $option.text(newText);

                $('#{{ id }}-select + .select2 input').focus();

                e.preventDefault();
            });
        </script>
        <button
            id="{{ id }}-cancel-button"
            data-testid="{{ id }}-cancel-button"
            class="inline-form-cancel-button btn btn-secondary"
            type="button"
            style="outline-offset: 0px;"
        >
            <i class="bi-x"></i>
        </button>
    </div>
{% endmacro %}

