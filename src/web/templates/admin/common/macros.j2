{%
    from '../../common/macros.j2' import
    tooltip_attributes,
    visibility_icon
%}

{% macro family_visibility_icon(family, class) %}
    <!-- family_visibility_icon() -->
    {{ visibility_icon('family', family.public, '', '', class) }}
    <!-- end family_visibility_icon() -->
{% endmacro %}

{% macro tournament_status_icon(tournament, class) %}
    <!-- tournament_status_icon() -->
    {% if not tournament.rounds %}
        {% set _icon_class='bi-exclamation-triangle-fill text-danger' %}
        {% set _tooltip_text='' %}
    {% elif not tournament.started %}
        {% set _icon_class='bi-pause-fill' %}
        {% set _tooltip_text=_('The tournament has not yet started.') %}
    {% elif tournament.playing %}
        {% set _icon_class='bi-caret-right-square-fill' %}
        {% set _tooltip_text=_('Round #%(round)d is running.', round=tournament.current_round) %}
    {% elif not tournament.finished %}
        {% set _icon_class='bi-pause-fill' %}
        {% set _tooltip_text=_('Round #%(round)d is finished.', round=tournament.current_round) %}
    {% else %}
        {% set _icon_class='bi-check-circle-fill text-success' %}
        {% set _tooltip_text=_('The tournament is finished.') %}
    {% endif %}
    <span
            class="fw-bold {{ class }}"
            {% if _tooltip_text %}{{ tooltip_attributes('info', _tooltip_text, 'top') }}{% endif %}
        >
        <i class="{{ _icon_class }}"></i>
    </span>
    <!-- end tournament_status_icon() -->
{% endmacro %}

{% macro player_record(player) %}
    <!-- player_record() -->
    <div class="d-flex gap-1 h-100 align-items-center">
        {% for pairing in player.pairings.values() %}
            {% set _box_class='bg-white border border-white text-dark' if pairing.color == 'W' else 'bg-dark border border-white text-white' %}
            {% set _text_style='line-height: 0;' %}
            {% if pairing.zero_point_bye %}
                {% set _text='<i class="bi bi-0-circle-fill"></i>' %}
                {% set _class='text-secondary' %}
                {% set _tooltip_text=_('Zero-Point Bye') %}
            {% elif pairing.not_paired %}
                {% set _text='' %}
                {% set _class='text-secondary' %}
            {% elif pairing.paired_no_result %}
                {% set _text='&nbsp;' %}
                {% set _class=_box_class %}
            {% elif pairing.exempt %}
                {% set _text='+' %}
                {% set _text_style='position: relative; top: 0.1em;' %}
                {% set _tooltip_text=_('Pairing Allocated Bye') %}
            {% elif pairing.loss %}
                {% set _text='L' if pairing.unrated_loss else '0' %}
                {% set _class=_box_class  %}
                {% set _text_style='position: relative; top: 0.1em;' %}
                {% set _tooltip_text=_('Unrated Loss') if pairing.unrated_loss else _('Loss') %}
            {% elif pairing.draw %}
                {% set _text='D' if pairing.unrated_draw else '=' %}
                {% set _class=_box_class %}
                {% set _tooltip_text=_('Unrated Draw') if pairing.unrated_draw else _('Draw') %}
            {% elif pairing.gain %}
                {% set _text='W' if pairing.unrated_gain else '1' %}
                {% set _class=_box_class %}
                {% set _text_style='position: relative; top: 0.1em;' %}
                {% set _tooltip_text=_('Unrated Win') if pairing.unrated_gain else _('Win') %}
            {% elif pairing.half_point_bye %}
                {% set _text='<i class="bi bi-circle-half"></i>' %}
                {% set _class='text-secondary' %}
                {% set _tooltip_text=_('Half-Point Bye') %}
            {% elif pairing.full_point_bye %}
                {% set _text='<i class="bi bi-1-circle-fill"></i>' %}
                {% set _class='text-secondary' %}
                {% set _tooltip_text=_('Full-Point Bye') %}
            {% elif pairing.forfeit_loss or pairing.double_forfeit %}
                {% set _text='-' %}
                {% set _class=_box_class %}
                {% set _tooltip_text=_('Forfeit Loss') %}
            {% elif pairing.forfeit_gain %}
                {% set _text='+' %}
                {% set _class=_box_class %}
                {% set _tooltip_text=_('Forfeit Win') %}
            {% else %}
                {% set _text='?' %}
                {% set _class='bg-danger text-white' %}
            {% endif %}
            <span
                class="player-record text-center p-0 m-0 {{ _class }}"
                {% if _tooltip_text %}
                    {{ tooltip_attributes('info', _tooltip_text) }}
                {% endif %}
                style="display: inline-flex; width: 1.5em; height: 1.5em; align-items: center; justify-content: center;"
            >
                <span style="{{ _text_style }}">
                    {{ _text|safe }}
                </span>
            </span>
        {% endfor %}
    </div>
    <!-- end player_record() -->
{% endmacro %}

{% macro admin_players_sort_link(url, icon, sort, admin_players_sort) %}
    <!-- admin_players_sort_link() -->
    {% if sort == 'alpha' %}
        {% set _tooltip_text=_('Sort the players by name.') %}
    {% elif sort == 'rating_desc' %}
        {% set _tooltip_text=_('Sort the players by rating (most rated first).') %}
    {% elif sort == 'rating_asc' %}
        {% set _tooltip_text=_('Sort the players by rating (less rated first).') %}
    {% elif sort == 'club' %}
        {% set _tooltip_text=_('Sort the players by club.') %}
    {% elif sort == 'yob_desc' %}
        {% set _tooltip_text=_('Sort the players by year of birth (youngest first).') %}
    {% elif sort == 'yob_asc' %}
        {% set _tooltip_text=_('Sort the players by year of birth (oldest first).') %}
    {% elif sort == 'category_desc' %}
        {% set _tooltip_text=_('Sort the players by category (oldest first).') %}
    {% elif sort == 'category_asc' %}
        {% set _tooltip_text=_('Sort the players by category (youngest first).') %}
    {% elif sort == 'tournament' %}
        {% set _tooltip_text=_('Sort the players by tournament.') %}
    {% else %}
        {% set _tooltip_text='Unknown sort [%(sort)s]'|format(sort=sort) %}
    {% endif %}
    <i
        class="{{ icon }} {% if admin_players_sort != sort %}cursor-pointer{% else %}text-danger{%endif %}"
        {% if admin_players_sort != sort %}
            hx-get="{{ url }}"
            hx-vals='{"admin_players_sort": "{{ sort }}"}'
            preload
            hx-target="body"
            hx-indicator="#please-wait"
        {% endif %}
        {{ tooltip_attributes('info', _tooltip_text, 'top') }}
    ></i>
    <!-- end admin_players_sort_link() -->
{% endmacro %}

{% macro gender_icon(gender) %}
    <!-- gender_icon() -->
    {% if gender.value == 0 %}
        {% set _icon_class='-' %}
    {% elif gender.value == 1 %}
        {% set _icon_class='bi-person-standing-dress' %}
    {% elif gender.value == 2 %}
        {% set _icon_class='bi-person-standing' %}
    {% else %}
        {% set _icon_class='bi-question' %}
    {% endif %}
    {% if _icon_class %}<i class="{{ _icon_class }}"></i>{% endif %}
    <!-- end gender_icon() -->
{% endmacro %}

{#
name: used by the query parameter
input_type: see *_input() below
label: the form label of the field
placeholder: the text inside text inputs when empty, also used as the text for the switches
help_text: the text printed below the input
data, errors: used to pre-fill the inputs and error messages (data[name] and errors[name] are used for this field)
error: if true, sets the field as "on error", event if errors[name] is not set
default_checkbox: if true, a checkbox is printed with the default message "by default", with query name <name>_checkbox
default_checkbox_text: another message to replace "by default"
default_value: the value to be set when the default checkbox is checked
select_options: a dict[str, str], keys are the select values and values are the select texts
number_min: the minimum value for numbers
number_max: the maximum value for numbers
number_step: the step value for numbers
radio_value: the value of radio buttons
disabled: if set to true, the field will be disabled
hx_get: the hx-get attribute of the input, optional
hx_target: the hx-target attribute of the input, optional
hx_on_before_request: the JS to run before the HTMX request (text inputs only)
hx_on_after_request: the JS to run after the HTMX request (text inputs only)
with_indicator: display a loading indicator, optional
#}

{% macro _generic_input(
    name,
    input_type,
    label='NO LABEL',
    placeholder='',
    help_text='NO HELP TEXT',
    data={},
    errors={},
    error=false,
    valid=false,
    password_visible=false,
    default_checkbox=false,
    default_checkbox_text='',
    default_value='',
    with_indicator=false,
    dropdown_id='',
    dropdown_item='',
    dropdown_classes='',
    select_options={},
    multiple_select=false,
    number_min='',
    number_max='',
    number_step='',
    radio_value='',
    info='',
    disabled=false,
    hx_get='',
    hx_post='',
    hx_target='',
    hx_indicator='',
    hx_trigger='',
    hx_include='',
    hx_swap='',
    hx_on_before_request='',
    hx_on_after_request='',
    hx_sync='',
    hx_vals=''
) %}
    <!-- {{ input_type }}_input({{ name }}) -->
        {% set id=name|replace('_', '-') %}
        {% set default_checkbox_name=name~'_checkbox' %}
        {% set default_checkbox_id=default_checkbox_name|replace('_', '-') %}
        {% if default_checkbox and data[default_checkbox_name] == 'on' %}
            {% set value=default_value %}
        {% else %}
            {% set value=data[name] %}
        {% endif %}
        <div class="input-block">
            <div class="d-flex align-items-center">
                {% if label %}
                    <label
                        for="{{ id }}"
                        class="form-check-label flex-grow-1 mb-1"
                    >
                        {{ label }}
                    </label>
                {% endif %}
                {% if default_checkbox %}
                    {{ default_checkbox_text or _('by default') }}
                    <input
                        data-testid="{{ default_checkbox_id }}"
                        id="{{ default_checkbox_id }}"
                        name="{{ default_checkbox_name }}"
                        type="checkbox"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        {% if data[default_checkbox_name] == 'on' %}checked{% endif %}
                        class="ms-2"
                    />
                {% endif %}
            </div>

            <div
                class="
                    pw-input-group
                    {% if input_type == 'password' %}input-group{% endif %}
                    {% if with_indicator %}d-flex align-items-center{% endif %}
                    {% if input_type == 'switch' %}form-check form-switch d-inline-block pe-3{% endif %}
                "
            >
                {% if input_type == 'select' %}
                    {% set selected=data[name].split(';') if multiple_select else [data[name]] %}
                    <select
                        name="{{ name }}"
                        id="{{ id }}"
                        data-testid="{{ id }}"
                        class="form-select {% if error or (name in errors) %}is-invalid{% endif %}"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        {% if disabled or (select_options|length <= 1 and not multiple_select) %}
                            disabled
                        {% endif %}
                        {% if multiple_select %}
                            multiple
                            style="display:none"
                            {% if placeholder %}
                                data-placeholder='{{ placeholder }}'
                            {% endif %}
                        {% endif %}
                    >
                        {% for key, text_or_options in select_options.items() %}
                            {% if text_or_options is string %}
                                <option value="{{ key }}" {% if key in selected %}selected{% endif %}>
                                    {{ text_or_options }}
                                </option>
                            {% else %}
                                <optgroup label="{{ key }}">
                                    {% for value, text in text_or_options.items() %}
                                        <option value="{{ value }}" {% if value in selected %}selected{% endif %}>
                                            {{ text }}
                                        </option>
                                    {% endfor %}
                                </optgroup>
                            {% endif %}
                        {% endfor %}
                    </select>
                    {% if multiple_select %}
                        <script>
                            $('#{{ id }}').select2({
                                theme: 'bootstrap-5',
                                width: '100%',
                                placeholder: $(this).data('placeholder'),
                            });
                            $('.select2-search__field').css('width', '100%');
                        </script>
                    {% elif select_options|length == 1 and not disabled %}
                        <input type="hidden" name="{{ name }}" value="{{ selected[0] }}" />
                    {% endif %}
                {% elif input_type == 'switch' %}
                    <input
                        id="{{ id }}"
                        name="{{ name }}"
                        data-testid="{{ id }}"
                        type="checkbox"
                        class="form-check-input"
                        value="on"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        {% if data[name] == 'on' %}checked{% endif %}
                        {% if disabled %}
                            disabled
                        {% endif %}
                    />
                    {{ placeholder }}
                {% elif input_type == 'radio' %}
                    <input
                        id="{{ id }}"
                        name="{{ name }}"
                        type="radio"
                        class="form-check-input"
                        value="{{ radio_value }}"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        {% if data[name] == radio_value %}checked{% endif %}
                        {% if disabled %}
                            disabled
                        {% endif %}
                    />
                        {{ placeholder }}
                        {% if info %}
                            <i
                                class="bi bi-info-circle-fill"
                                {{ macros.tooltip_attributes('info', info, 'top') }}
                            ></i>
                        {% endif %}
                {% else %}
                    {% if disabled %}
                        <input
                            id="{{ id }}"
                            name="{{ name }}"
                            data-testid="{{ id }}"
                            type="hidden"
                            value="{{ value }}"
                        />
                    {% endif %}
                    <input
                        id="{{ id }}"
                        name="{{ name }}"
                        data-testid="{{ id }}"
                        type="{{ input_type if not password_visible else 'text' }}"
                        {% if number_min != '' %}
                            min="{{ number_min }}"
                        {% endif %}
                        {% if number_max != '' %}
                            max="{{ number_max }}"
                        {% endif %}
                        {% if number_step != '' %}
                            step="{{ number_step }}"
                        {% endif %}
                        class="form-control {% if error or (name in errors) %}is-invalid{% endif %} {% if valid %}is-valid{% endif %}"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        placeholder="{{ placeholder }}"
                        value="{{ value }}"
                        {% if disabled or (default_checkbox and data[default_checkbox_name] == 'on') %}disabled{% endif %}
                        {% if hx_get %}
                            hx-get="{{ hx_get }}"
                        {% endif %}
                        {% if hx_post %}
                            hx-post="{{ hx_post }}"
                        {% endif %}
                        {% if hx_target %}
                            hx-target="{{ hx_target }}"
                        {% endif %}
                        {% if hx_indicator %}
                            hx-indicator="{{ hx_indicator }}"
                        {% endif %}
                        {% if with_indicator %}
                            hx-indicator="#{{ id }}_indicator"
                        {% endif %}
                        {% if hx_trigger %}
                            hx-trigger="{{ hx_trigger }}"
                        {% endif %}
                        {% if hx_swap %}
                            hx-swap="{{ hx_swap }}"
                        {% endif %}
                        {% if hx_include %}
                            hx-include="{{ hx_include }}"
                        {% endif %}
                        {% if hx_on_before_request %}
                            hx-on::before-request="{{ hx_on_before_request }}"
                        {% endif %}
                        {% if hx_on_after_request %}
                            hx-on::after-request="{{ hx_on_after_request }}"
                        {% endif %}
                        {% if hx_sync %}
                            hx-sync="{{ hx_sync }}"
                        {% endif %}
                        {% if hx_vals %}
                            hx-vals="{{ hx_vals }}"
                        {% endif %}
                    />
                    {% if input_type == 'password' %}
                        <i
                            id="{{ id }}-toggle-password"
                            data-testid="{{ id }}-toggle-password"
                            class="input-group-text {{ 'bi-eye-slash-fill' if not password_visible else 'bi-eye-fill' }} ps-2 pt-2 cursor-pointer {% if name in errors %}is-invalid{% endif %} {% if valid %}is-valid{% endif %}"
                            hx-on:click="toggle_password(event, '#{{ id }}')"
                        ></i>
                    {% endif %}
                    {% if with_indicator %}
                        <div
                            id="{{ id }}_indicator"
                            class="htmx-indicator input-htmx-indicator"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                xmlns:xlink="http://www.w3.org/1999/xlink"
                                viewBox="0 0 169 307"
                            >
                                <path
                                    fill-rule="evenodd"
                                    fill="currentColor"
                                    d="M147.1000,150.000 C139.780,158.150 130.313,157.457 125.1000,158.000 C116.586,159.185 112.789,134.954 98.000,125.1000 C90.943,121.731 83.688,121.332 78.1000,117.1000 C66.320,108.988 75.357,115.062 66.1000,107.000 C59.260,119.128 62.904,133.801 69.000,142.000 C79.028,155.494 111.1000,177.000 111.1000,177.000 C122.204,183.307 138.166,192.314 143.369,196.214 C148.567,200.114 152.716,204.314 155.819,208.814 C158.917,213.314 161.069,218.264 162.269,223.664 C163.469,229.064 164.069,235.064 164.069,241.664 C164.069,264.267 157.516,280.716 144.419,291.014 C131.317,301.317 119.047,306.464 83.669,306.464 C59.266,306.464 41.819,301.167 31.319,290.564 C20.819,279.966 15.569,264.764 15.569,244.964 L15.569,236.264 L58.769,236.264 L58.769,242.564 C58.769,247.566 59.167,252.117 59.969,256.214 C60.766,260.316 62.266,263.766 64.469,266.564 C66.667,269.367 69.616,271.566 73.319,273.164 C77.017,274.767 81.667,275.564 87.269,275.564 C104.820,275.564 105.817,273.417 111.119,269.114 C116.416,264.816 119.069,258.164 119.069,249.164 C119.069,244.364 118.417,240.216 117.119,236.714 C115.816,233.217 113.669,230.067 110.669,227.264 C107.669,224.466 103.717,221.916 98.819,219.614 L49.1000,186.1000 C29.036,170.344 17.657,160.157 7.1000,138.1000 C-4.382,111.874 -0.076,84.855 12.1000,60.000 C22.228,42.460 44.432,14.077 90.000,11.1000 C99.590,11.563 103.852,-2.652 130.1000,1.000 C139.293,2.115 114.725,26.386 120.1000,31.000 C143.374,50.482 134.753,73.335 138.1000,79.1000 C143.877,87.654 149.135,98.532 159.1000,112.1000 C168.078,123.756 168.627,134.834 169.000,134.000 C164.812,143.370 157.416,149.184 147.1000,150.000 ZM120.000,49.1000 C116.719,47.168 112.788,46.733 111.1000,47.000 C111.212,47.267 112.288,51.666 113.1000,55.000 C115.331,57.593 123.000,60.000 123.000,60.000 C123.000,60.000 123.281,52.832 120.000,49.1000 Z"
                                />
                            </svg>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
            {% if info and input_type != 'radio' %}
                <i
                    class="bi bi-info-circle-fill"
                    {{ macros.tooltip_attributes('info', info, 'top') }}
                ></i>
            {% endif %}
            {% if dropdown_id %}
                <ul id="{{ dropdown_id }}" class="dropdown-menu p-0 mt-1 {{ dropdown_classes }}">
                    {% if dropdown_item %}
                        <li class="dropdown-item no-hover text-nowrap">
                            <span class="fst-italic">{{ dropdown_item }}</span>
                        </li>
                    {% endif %}
                </ul>
            {% endif %}
            {% if help_text %}
                <div id="{{ id }}-help" class="form-text">
                    {{ help_text }}
                </div>
            {% endif %}
            {% if name in errors %}
                <div id="{{ id }}-error" class="form-text invalid-feedback">
                    {{ errors[name] }}
                </div>
            {% endif %}
        </div>
        {% if default_checkbox %}
            <script>
                $('#{{ default_checkbox_id }}').click(function() {
                    if ($(this).is(':checked')) {
                        $('#{{ id }}').val('{{ default_value }}');
                        $('#{{ id }}').prop('disabled', true);
                    } else {
                        $('#{{ id }}').prop('disabled', false);
                    }
                });
            </script>
        {% endif %}
    <!-- end {{ input_type }}_input({{ name }}) -->
{% endmacro %}

