{#
name: used by the query parameter
input_type: see *_input() below
label: the form label of the field
placeholder: the text inside text inputs when empty, also used as the text for the switches
help_text: the text printed below the input
data, errors: used to pre-fill the inputs and error messages (data[name] and errors[name] are used for this field)
error: if true, sets the field as "on error", event if errors[name] is not set
default_checkbox: if true, a checkbox is printed with the default message "by default", with query name <name>_checkbox
default_checkbox_text: another message to replace "by default"
default_value: the value to be set when the default checkbox is checked
select_options: a dict[str, str], keys are the select values and values are the select texts
number_min: the minimum value for numbers
number_max: the maximum value for numbers
number_step: the step value for numbers
radio_value: the value of radio buttons
disabled: if set to true, the field will be disabled
hx_get: the hx-get attribute of the input, optional
hx_target: the hx-target attribute of the input, optional
hx_on_before_request: the JS to run before the HTMX request (text inputs only)
hx_on_after_request: the JS to run after the HTMX request (text inputs only)
with_indicator: display a loading indicator, optional
#}

{% macro _generic_input(
    name,
    input_type,
    label='NO LABEL',
    placeholder='',
    doc_icon='',
    help_text='',
    tooltip_text='',
    data={},
    errors={},
    error=false,
    valid=false,
    password_visible=false,
    default_checkbox=false,
    default_checkbox_text='',
    default_checkbox_tooltip='',
    default_value='',
    with_indicator=false,
    select_options={},
    onchange='',
    multiple_select=false,
    tooltip_select=false,
    select_search_placeholder='',
    select_search_disabled=false,
    select_all=false,
    file_accept='',
    min_date='',
    max_date='',
    on_date_picker_hide='',
    date_now_button=false,
    date_position='',
    number_min='',
    number_max='',
    min_disabled=false,
    max_disabled=false,
    max_placeholder='',
    input_tooltip='',
    number_step='',
    radio_value='',
    info='',
    autocomplete='',
    disabled=false,
    prevent_wrapping=false,
    hx_get='',
    hx_post='',
    hx_target='',
    hx_indicator='',
    hx_trigger='',
    hx_include='',
    hx_swap='',
    hx_on_before_request='',
    hx_on_after_request='',
    hx_sync='',
    hx_vals=''
) %}
    <!-- {{ input_type }}_input({{ name }}) -->
        {% set id=name|replace('_', '-') %}
        {% set default_checkbox_name=name~'_checkbox' %}
        {% set default_checkbox_id=default_checkbox_name|replace('_', '-') %}
        {% if default_checkbox and data[default_checkbox_name] == 'on' %}
            {% set value=default_value %}
        {% else %}
            {% set value=data[name] %}
        {% endif %}
        <div id="{{id}}-wrapper" class="input-block position-relative{% if prevent_wrapping %} flex-nowrap{% endif %}">
            <div class="d-flex align-items-center">
                {%- if label -%}
                    <span
                        id="{{ id }}-label"
                        for="{{ id }}"
                        class="form-check-label flex-grow-1"
                    >
                        <span id="{{ id }}-label-text">{{- label -}}</span>
                        {%- if doc_icon -%}
                            <span class="text-nowrap">{{ macros.doc_icon(doc_icon, 'ms-2') }}</span>
                        {%- endif -%}
                        {%- if tooltip_text -%}
                            <span class="text-nowrap"></span>
                                <i
                                    class="bi bi-info-circle-fill ms-2"
                                    {{ macros.tooltip_attributes('', tooltip_text, 'top') }}
                                ></i>
                            </span>
                        {%- endif -%}
                    </span>
                {%- endif -%}
            </div>

            <div
                {% if input_type not in ['switch', 'checkbox', 'radio'] %}
                    id="{{ id }}-input-container"
                    {% if input_tooltip %}
                        {{ macros.tooltip_attributes('', input_tooltip, 'top') }}
                    {% endif %}
                {% endif %}
                class="
                    pw-input-group
                    {% if input_type in ['password', 'search', 'integer-range', 'select-range'] %}input-group{% endif %}
                    {% if default_checkbox %}input-group{% endif %}
                    {% if input_type == 'switch' %}form-check form-switch d-inline-block{% endif %}
                    {% if input_type == 'checkbox' %}form-check d-inline-block{% endif %}
                "
            >
                {% if input_type == 'select' %}
                    {{ select_content(
                        id=id,
                        name=name,
                        options=select_options,
                        selected=data.get(name, '').split(';') if multiple_select else [data[name]],
                        disabled=disabled,
                        multiple=multiple_select,
                        placeholder=placeholder,
                        multiple_select_all=select_all,
                        search_placeholder=select_search_placeholder,
                        search_disabled=select_search_disabled,
                        error=error or (name in errors),
                        tooltip_select=tooltip_select,
                        onchange=onchange,
                    ) }}
                {% elif input_type == 'switch' or input_type == 'checkbox' %}
                    <span
                        id="{{ id }}-input-container"
                        {% if input_tooltip %}
                            {{ macros.tooltip_attributes('', input_tooltip, 'top') }}
                        {% endif %}
                    >
                        <input
                            id="{{ id }}"
                            name="{{ name }}"
                            data-testid="{{ id }}"
                            type="checkbox"
                            class="form-check-input {% if error or (name in errors) %}is-invalid{% endif %} {% if valid %}is-valid{% endif %}"
                            value="on"
                            aria-describedby="{{ id }}-help {{ id }}-error"
                            {% if data[name] == 'on' %}checked{% endif %}
                            {% if disabled %}
                                disabled
                            {% endif %}
                        />
                        {{ placeholder }}
                    </span>
                    {% if doc_icon %}<span >{{ macros.doc_icon(doc_icon, 'ms-2') }}</span>{% endif %}
                    {%- if tooltip_text and not label -%}
                        <span class="text-nowrap">
                            <i
                                class="bi bi-info-circle-fill ms-2"
                                {{ macros.tooltip_attributes('', tooltip_text, 'top') }}
                            ></i>
                        </span>
                    {%- endif -%}
                {% elif input_type == 'radio' %}
                    <input
                        id="{{ id }}"
                        name="{{ name }}"
                        type="radio"
                        class="form-check-input"
                        value="{{ radio_value }}"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        {% if data[name] == radio_value %}checked{% endif %}
                        {% if disabled %}
                            disabled
                        {% endif %}
                    />
                    {{ placeholder }}
                    {% if info %}
                        <i
                            class="bi bi-info-circle-fill"
                            {{ macros.tooltip_attributes('', info, 'top') }}
                        ></i>
                    {% endif %}
                {% elif input_type == 'integer-range' %}
                    <input
                        id="{{ id }}-min"
                        name="{{ name }}_min"
                        class="form-control"
                        type="number"
                        step="1"
                        min="{{ number_min }}"
                        value="{{ data[name ~ '_min'] }}"
                        placeholder="{{ placeholder }}"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        {% if input_tooltip or min_disabled %}
                            disabled
                        {% endif %}
                    />
                    <input
                        id="{{ id }}-max"
                        name="{{ name }}_max"
                        class="form-control"
                        type="number"
                        step="1"
                        max="{{ number_max }}"
                        value="{{ data[name ~ '_max'] }}"
                        placeholder="{{ max_placeholder }}"
                        {% if input_tooltip or max_disabled %}
                            disabled
                        {% endif %}
                    />
                {% elif input_type == 'select-range' %}
                    <div class="form-control p-0 border-0 select2-border-radius-0-right">
                        {{ select_content(
                            id=id ~ '-min',
                            name=name ~ '_min',
                            options=select_options,
                            selected=[data[name ~ '_min']],
                            disabled=disabled,
                            search_disabled=true,
                            placeholder=placeholder,
                            error=error or (name in errors),
                            tooltip_select=tooltip_select,
                            onchange=onchange,
                        ) }}
                    </div>
                    <div class="form-control p-0 border-0 select2-border-radius-0-left">
                    {{ select_content(
                        id=id ~ '-max',
                        name=name ~ '_max',
                        options=select_options,
                        selected=[data[name ~ '_max']],
                        disabled=disabled,
                        search_disabled=true,
                        placeholder=max_placeholder,
                        error=error or (name in errors),
                        tooltip_select=tooltip_select,
                        onchange=onchange,
                    ) }}
                    </div>
                {% else %}
                    {% set use_date_picker = input_type in ['datetime', 'date', 'date-range'] %}
                    {% if disabled %}
                        <input
                            id="{{ id }}-hidden"
                            name="{{ name }}"
                            type="hidden"
                            value="{{ value }}"
                        />
                    {% endif %}
                    {% if input_type == 'search' %}
                        {% if with_indicator %}
                            {{ search_indicator(id ~ '_indicator') }}
                        {% else %}
                            <span class="input-group-text px-2 pt-2">
                                <i class="bi bi-search"></i>
                            </span>
                        {% endif %}
                    {% endif %}
                    <input
                        id="{{ id }}"
                        name="{{ name }}"
                        data-testid="{{ id }}"
                        type="{{ 'text' if password_visible or use_date_picker else input_type }}"
                        autocomplete="{{ autocomplete or 'off' }}"
                        {% if number_min != '' %}
                            min="{{ number_min }}"
                        {% endif %}
                        {% if number_max != '' %}
                            max="{{ number_max }}"
                        {% endif %}
                        {% if number_step != '' %}
                            step="{{ number_step }}"
                        {% endif %}

                        {% if file_accept %}
                            accept="{{ file_accept }}"
                        {% endif %}
                        class="form-control {% if error or (name in errors) %}is-invalid{% endif %} {% if valid %}is-valid{% endif %}"
                        aria-describedby="{{ id }}-help {{ id }}-error"
                        placeholder="{{ placeholder }}"
                        value="{{ value }}"
                        {% if disabled or (default_checkbox and data[default_checkbox_name] == 'on') %}disabled{% endif %}
                        {% if hx_get %}
                            hx-get="{{ hx_get }}"
                        {% endif %}
                        {% if hx_post %}
                            hx-post="{{ hx_post }}"
                        {% endif %}
                        {% if hx_target %}
                            hx-target="{{ hx_target }}"
                        {% endif %}
                        {% if hx_indicator %}
                            hx-indicator="{{ hx_indicator }}"
                        {% endif %}
                        {% if with_indicator %}
                            hx-indicator="#{{ id }}_indicator"
                        {% endif %}
                        {% if hx_trigger %}
                            hx-trigger="{{ hx_trigger }}"
                        {% endif %}
                        {% if hx_swap %}
                            hx-swap="{{ hx_swap }}"
                        {% endif %}
                        {% if hx_include %}
                            hx-include="{{ hx_include }}"
                        {% endif %}
                        {% if hx_on_before_request %}
                            hx-on::before-request="{{ hx_on_before_request }}"
                        {% endif %}
                        {% if hx_on_after_request %}
                            hx-on::after-request="{{ hx_on_after_request }}"
                        {% endif %}
                        {% if hx_sync %}
                            hx-sync="{{ hx_sync }}"
                        {% endif %}
                        {% if hx_vals %}
                            hx-vals="{{ hx_vals }}"
                        {% endif %}
                    />
                    {% if input_type == 'password' %}
                        <i
                            id="{{ id }}-toggle-password"
                            data-testid="{{ id }}-toggle-password"
                            class="input-group-text {{ 'bi-eye-slash-fill' if not password_visible else 'bi-eye-fill' }} ps-2 pt-2 cursor-pointer {% if name in errors %}is-invalid{% endif %} {% if valid %}is-valid{% endif %}"
                            hx-on:click="toggle_password(event, '#{{ id }}')"
                        ></i>
                    {% endif %}
                    {% if use_date_picker %}
                        {{ set_date_picker(
                            id,
                            input_type=input_type,
                            min_date=min_date,
                            max_date=max_date,
                            on_hide=on_date_picker_hide,
                            now_button=date_now_button,
                            position=date_position,
                        ) }}
                    {% endif %}
                    {% if default_checkbox %}
                        <div
                            class="input-group-text"
                            {% if default_checkbox_tooltip %}
                                {{ macros.tooltip_attributes('info', default_checkbox_tooltip, 'top') }}
                            {% endif %}
                        >
                            <input
                                data-testid="{{ default_checkbox_id }}"
                                id="{{ default_checkbox_id }}"
                                name="{{ default_checkbox_name }}"
                                type="checkbox"
                                class="form-check-input me-2 mb-2"
                                aria-describedby="{{ id }}-help {{ id }}-error"
                                {% if data[default_checkbox_name] == 'on' %}checked{% endif %}

                            />
                            {{ default_checkbox_text or _('Use default') }}
                        </div>
                    {% endif %}
                    {% if with_indicator and not input_type == 'search' %}
                        <div
                            id="{{ id }}_indicator"
                            class="htmx-indicator input-htmx-indicator"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                xmlns:xlink="http://www.w3.org/1999/xlink"
                                viewBox="0 0 169 307"
                            >
                                <path
                                    fill-rule="evenodd"
                                    fill="currentColor"
                                    d="M147.1000,150.000 C139.780,158.150 130.313,157.457 125.1000,158.000 C116.586,159.185 112.789,134.954 98.000,125.1000 C90.943,121.731 83.688,121.332 78.1000,117.1000 C66.320,108.988 75.357,115.062 66.1000,107.000 C59.260,119.128 62.904,133.801 69.000,142.000 C79.028,155.494 111.1000,177.000 111.1000,177.000 C122.204,183.307 138.166,192.314 143.369,196.214 C148.567,200.114 152.716,204.314 155.819,208.814 C158.917,213.314 161.069,218.264 162.269,223.664 C163.469,229.064 164.069,235.064 164.069,241.664 C164.069,264.267 157.516,280.716 144.419,291.014 C131.317,301.317 119.047,306.464 83.669,306.464 C59.266,306.464 41.819,301.167 31.319,290.564 C20.819,279.966 15.569,264.764 15.569,244.964 L15.569,236.264 L58.769,236.264 L58.769,242.564 C58.769,247.566 59.167,252.117 59.969,256.214 C60.766,260.316 62.266,263.766 64.469,266.564 C66.667,269.367 69.616,271.566 73.319,273.164 C77.017,274.767 81.667,275.564 87.269,275.564 C104.820,275.564 105.817,273.417 111.119,269.114 C116.416,264.816 119.069,258.164 119.069,249.164 C119.069,244.364 118.417,240.216 117.119,236.714 C115.816,233.217 113.669,230.067 110.669,227.264 C107.669,224.466 103.717,221.916 98.819,219.614 L49.1000,186.1000 C29.036,170.344 17.657,160.157 7.1000,138.1000 C-4.382,111.874 -0.076,84.855 12.1000,60.000 C22.228,42.460 44.432,14.077 90.000,11.1000 C99.590,11.563 103.852,-2.652 130.1000,1.000 C139.293,2.115 114.725,26.386 120.1000,31.000 C143.374,50.482 134.753,73.335 138.1000,79.1000 C143.877,87.654 149.135,98.532 159.1000,112.1000 C168.078,123.756 168.627,134.834 169.000,134.000 C164.812,143.370 157.416,149.184 147.1000,150.000 ZM120.000,49.1000 C116.719,47.168 112.788,46.733 111.1000,47.000 C111.212,47.267 112.288,51.666 113.1000,55.000 C115.331,57.593 123.000,60.000 123.000,60.000 C123.000,60.000 123.281,52.832 120.000,49.1000 Z"
                                />
                            </svg>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
            {% if input_type == 'integer-range' %}
                {% if input_tooltip or min_disabled %}
                    <input
                        id="{{ id }}-min"
                        name="{{ name }}_min"
                        type="hidden"
                        value="{{ data[name ~ '_min'] }}"
                    />
                {% endif %}
                {% if input_tooltip or max_disabled %}
                    <input
                        id="{{ id }}-max"
                        name="{{ name }}_max"
                        type="hidden"
                        value="{{ data[name ~ '_max'] }}"
                    />
                {% endif %}
            {% endif %}
            {% if info and input_type != 'radio' %}
                <i
                    class="bi bi-info-circle-fill ms-2"
                    {{ macros.tooltip_attributes('', info, 'top') }}
                ></i>
            {% endif %}
            {% if help_text %}
                <div id="{{ id }}-help" class="form-text w-100">
                    {{ help_text }}
                </div>
            {% endif %}
            {% if name in errors %}
                <div
                    id="{{ id }}-error"
                    class="form-text invalid-feedback"
                    style="display:block"
                >
                    {{ errors[name] }}
                </div>
            {% endif %}
        </div>
        {% if default_checkbox %}
            <script>
                $('#{{ default_checkbox_id }}').click(function() {
                    if ($(this).is(':checked')) {
                        $('#{{ id }}').val('{{ default_value }}');
                        $('#{{ id }}').prop('disabled', true);
                    } else {
                        $('#{{ id }}').prop('disabled', false);
                    }
                });
            </script>
        {% endif %}
    <!-- end {{ input_type }}_input({{ name }}) -->
{% endmacro %}

