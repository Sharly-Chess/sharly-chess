{% macro display_controller_assign_dropdown(
    display_controllers,
    object_type,
    object_uniq_id
) %}
    <div class="dropdown d-inline" {{ macros.tooltip_attributes('info', _('Assign to a display controller.'), 'top') }}>
        <button
            class="btn btn-sm btn-outline-primary dropdown-toggle mx-auto" type="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
            {% if display_controllers|length == 0 %}
                disabled
            {% endif %}
        >
            <i class="bi bi-box-arrow-in-right"></i>
        </button>
        <ul class="dropdown-menu">
            {% for display_controller in display_controllers %}
                <li>
                    <button
                        class="dropdown-item text-start cursor-pointer"
                        hx-patch="{{ url_for('admin-display-controller-assign', event_uniq_id=admin_event.uniq_id, display_controller_id=display_controller.id, type=object_type, object_uniq_id=object_uniq_id) }}"
                            hx-indicator="#please-wait"
                    >
                        <b>{{ display_controller.name }}</b> {% if display_controller.assigned_object %}{{ _('(replace [%(object_uniq_id)s])', object_uniq_id=display_controller.assigned_object.uniq_id) }}{% endif %}
                    </button>
                </li>
            {% endfor %}
        </ul>
    </div>
{% endmacro %}

{% macro split_submit_buttons(
    options,
    active_option,
    form_id='modal-form'
) %}
    <div class="btn-group dropup">
        <button
            type="submit"
            data-testid="{{ active_option }}-button"
            form="{{ form_id }}"
            name="{{ active_option }}"
            class="btn btn-primary"
        >
            {{ options[active_option] }}
        </button>
        <button
            type="button"
            class="btn btn-primary dropdown-toggle dropdown-toggle-split"
            data-bs-toggle="dropdown"
            aria-expanded="false"
        >
            <span class="visually-hidden">Toggle Dropdown</span>
        </button>
        <ul class="dropdown-menu">
            {% for option_id, option_name in options.items() %}
                <button
                    type="submit"
                    name="{{ option_id }}"
                    form="{{ form_id }}"
                    class="dropdown-item {% if option_id == active_option %}active{% endif %}"
                >
                    {{ option_name }}
                </li>
            {% endfor %}
        </ul>
    </div>
{% endmacro %}

{% macro create_with_add_other_split_buttons(is_add_other_active) %}
    {{ split_submit_buttons(
        options={'create': _('Create'), 'add_other': _('Create and add another')},
        active_option='add_other' if is_add_other_active else 'create'
    )}}
{% endmacro %}
